@@ -2210,6 +2210,56 @@ export async function runServeHttp(engine: BrainEngine, options: ServeHttpOption
         return;
       }
 
+      // Embedded engines need one physical owner. The legacy 202 path below
+      // only admits a queue job; it requires a separate worker to persist it.
+      // `Prefer: wait=persisted` is the explicit acknowledged mode: the HTTP
+      // owner dispatches through its already-connected IngestionService and
+      // returns only after canonical persistence has accepted or deduplicated
+      // the event. Existing callers that omit the header keep the 202 contract.
+      const waitForPersistence = (req.header('prefer') ?? '')
+        .split(',')
+        .map((value) => value.trim().toLowerCase())
+        .includes('wait=persisted');
+      if (waitForPersistence) {
+        if (!options.ingestionService) {
+          res.status(503).json({
+            error: 'persisted_ingestion_unavailable',
+            message: 'Owner-local persisted ingestion is not enabled.',
+          });
+          return;
+        }
+        const outcome = await options.ingestionService.submit(event);
+        if (outcome.kind === 'accepted' || outcome.kind === 'duplicate') {
+          res.status(200).json({
+            status: outcome.kind,
+            source_id: outcome.source_id,
+            slug: outcome.slug,
+            source_content_hash: contentHash,
+            content_hash: outcome.content_hash,
+          });
+          return;
+        }
+        if (outcome.kind === 'retryable') {
+          if (typeof outcome.retry_after_ms === 'number') {
+            res.setHeader('Retry-After', Math.max(1, Math.ceil(outcome.retry_after_ms / 1000)));
+          }
+          res.status(503).json({
+            error: outcome.code,
+            message: outcome.message,
+            source_id: outcome.source_id,
+            ...(outcome.slug ? { slug: outcome.slug } : {}),
+          });
+          return;
+        }
+        res.status(422).json({
+          error: outcome.code,
+          message: outcome.message,
+          source_id: outcome.source_id,
+          ...(outcome.slug ? { slug: outcome.slug } : {}),
+        });
+        return;
+      }
+
