     };
   }
 
+  /**
+   * Submit one already-validated event through the owner-local persistence
+   * lane and wait for its durable acknowledgment. Network surfaces call this
+   * instead of enqueueing work for a second process, which would violate the
+   * single-owner contract of embedded engines such as PGLite.
+   */
+  submit(event: IngestionEvent): Promise<IngestionEmitOutcome> {
+    return this.enqueueDispatch(event);
+  }
+
