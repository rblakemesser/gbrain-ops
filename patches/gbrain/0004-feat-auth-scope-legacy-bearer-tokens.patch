         ? (permissions as Record<string, unknown>).source_id
         : undefined;
+      const scopeGrant = permissions && typeof permissions === 'object'
+        ? (permissions as Record<string, unknown>).scopes
+        : undefined;
+      const scopes = Array.isArray(scopeGrant)
+        ? scopeGrant.filter((scope): scope is string => typeof scope === 'string' && ['read', 'write', 'admin'].includes(scope))
+        : ['read', 'write', 'admin'];
       const { sourceId, allowedSources } = parseLegacyTokenScope(sourceGrant);
       return {
         token,
         clientId: name,
         clientName: name,
-        scopes: ['read', 'write', 'admin'],
+        scopes,
         expiresAt: Math.floor(Date.now() / 1000) + 365 * 24 * 3600, // Legacy tokens never expire — set 1yr future
         // Legacy tokens without an explicit permissions.source_id grant keep
         // the historical 'default' source floor. Array grants become
diff --git a/src/mcp/http-transport.ts b/src/mcp/http-transport.ts
index c3ff28c2..1706b943 100644
--- a/src/mcp/http-transport.ts
+++ b/src/mcp/http-transport.ts
@@ -206,17 +206,20 @@ export async function startHttpTransport(opts: HttpTransportOptions) {
         .catch(() => { /* fire-and-forget */ });
       // v0.28: extract per-token takes-holder allow-list. Fail-safe default
       // is ['world'] — a token with no permissions row sees public claims only.
-      const perms = (row as { permissions?: { takes_holders?: unknown; source_id?: unknown } }).permissions;
+      const perms = (row as { permissions?: { takes_holders?: unknown; source_id?: unknown; scopes?: unknown } }).permissions;
       const allowList = Array.isArray(perms?.takes_holders)
         ? (perms!.takes_holders as unknown[]).filter(h => typeof h === 'string') as string[]
         : ['world'];
       // #1336: honor the operator-set source grant stored on the token.
       const { sourceId, allowedSources } = parseLegacyTokenScope(perms?.source_id);
+      const scopes = Array.isArray(perms?.scopes)
+        ? perms.scopes.filter((scope): scope is string => typeof scope === 'string' && ['read', 'write', 'admin'].includes(scope))
+        : ['read', 'write', 'admin'];
       const auth: AuthInfo = {
         token,
         clientId: rowId,
         clientName: rowName,
-        scopes: [],
+        scopes,
         sourceId,
         ...(allowedSources ? { allowedSources } : {}),
       };
diff --git a/test/auth-create-args.test.ts b/test/auth-create-args.test.ts
index 3ce9e775..5e28150a 100644
--- a/test/auth-create-args.test.ts
+++ b/test/auth-create-args.test.ts
@@ -5,13 +5,14 @@ describe('parseAuthCreateArgs', () => {
   test('bare name (no flag) resolves the name — regression for the dropped-name bug', () => {
     // Pre-fix this returned name='' because rest[takesIdx+1] === rest[0] when
     // takesIdx === -1, excluding the only positional from the search.
-    expect(parseAuthCreateArgs(['claude-code'])).toEqual({ name: 'claude-code', takesHolders: undefined });
+    expect(parseAuthCreateArgs(['claude-code'])).toEqual({ name: 'claude-code', takesHolders: undefined, scopes: undefined });
   });
 
   test('name + --takes-holders', () => {
     expect(parseAuthCreateArgs(['claude-code', '--takes-holders', 'world,garry'])).toEqual({
       name: 'claude-code',
       takesHolders: ['world', 'garry'],
+      scopes: undefined,
     });
   });
 
@@ -19,6 +20,7 @@ describe('parseAuthCreateArgs', () => {
     expect(parseAuthCreateArgs(['--takes-holders', 'world', 'claude-code'])).toEqual({
       name: 'claude-code',
       takesHolders: ['world'],
+      scopes: undefined,
     });
   });
 
@@ -35,4 +37,13 @@ describe('parseAuthCreateArgs', () => {
   test('takes-holders trims + drops empties', () => {
     expect(parseAuthCreateArgs(['n', '--takes-holders', ' world , , garry ']).takesHolders).toEqual(['world', 'garry']);
   });
+
+  test('scopes may be comma or whitespace separated and are not mistaken for the name', () => {
+    expect(parseAuthCreateArgs(['--scopes', 'read,write', 'reader'])).toEqual({
+      name: 'reader',
+      takesHolders: undefined,
+      scopes: ['read', 'write'],
+    });
+    expect(parseAuthCreateArgs(['reader', '--scopes', 'read write']).scopes).toEqual(['read', 'write']);
+  });
 });
