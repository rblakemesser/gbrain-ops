index 00000000..b3c602cf
--- /dev/null
+++ b/src/core/ingestion/config.ts
@@ -0,0 +1,179 @@
+/**
+ * Read-only runtime projection from file-plane ingestion instance config to
+ * the existing IngestionSource registry and daemon SourceRegistration shape.
+ *
+ * This is deliberately not a second plugin framework: kinds come exclusively
+ * from loadSkillpackSources(), logical provenance comes exclusively from the
+ * supplied engine's sources table, and lifecycle remains IngestionDaemon's.
+ */
+
+import type { BrainEngine } from '../engine.ts';
+import type { GBrainConfig, IngestionInstanceConfig } from '../config.ts';
+import { fetchSource } from '../sources-load.ts';
+import type { SourceRegistration } from './types.ts';
+import type { LoadedIngestionSource } from './skillpack-load.ts';
+
+export class IngestionConfigError extends Error {
+  constructor(message: string) {
+    super(message);
+    this.name = 'IngestionConfigError';
+  }
+}
+
+/**
+ * Instantiate enabled configured sources after strict, read-only binding to
+ * registered logical sources. The returned registrations can be handed
+ * directly to IngestionDaemon.register().
+ */
+export async function loadConfiguredSources(
+  engine: BrainEngine,
+  config: GBrainConfig,
+  loadedSources: readonly LoadedIngestionSource[],
+): Promise<SourceRegistration[]> {
+  const rawIngestion = (config as { ingestion?: unknown }).ingestion;
+  if (rawIngestion === undefined) return [];
+  if (rawIngestion === null || typeof rawIngestion !== 'object' || Array.isArray(rawIngestion)) {
+    throw new IngestionConfigError('ingestion must be a plain object');
+  }
+  const ingestion = rawIngestion as Record<string, unknown>;
+  if (ingestion.enabled !== undefined && typeof ingestion.enabled !== 'boolean') {
+    throw new IngestionConfigError('ingestion.enabled must be boolean');
+  }
+  if (ingestion.enabled === false) return [];
+  if (ingestion.sources === undefined) return [];
+  if (!Array.isArray(ingestion.sources)) {
+    throw new IngestionConfigError('ingestion.sources must be an array');
+  }
+
+  const loadedByKind = new Map(
+    loadedSources.map((loaded) => [loaded.declaration.kind, loaded] as const),
+  );
+  const seenIds = new Set<string>();
+  const registrations: SourceRegistration[] = [];
+
+  for (const raw of ingestion.sources as unknown[]) {
+    const instance = validateInstance(raw);
+    if (seenIds.has(instance.id)) {
+      throw new IngestionConfigError(
+        `duplicate ingestion instance id '${instance.id}'`,
+      );
+    }
+    seenIds.add(instance.id);
+    if (instance.enabled === false) continue;
+
+    const loaded = loadedByKind.get(instance.kind);
+    if (!loaded) {
+      throw new IngestionConfigError(
+        `ingestion instance '${instance.id}' references unloaded kind '${instance.kind}'`,
+      );
+    }
+
+    // Reuse the canonical single-row source loader against the owner engine.
+    // No engine is constructed here and no config/DB writes are performed.
+    const registeredSource = await fetchSource(engine, instance.sourceId);
+    if (!registeredSource) {
+      throw new IngestionConfigError(
+        `ingestion instance '${instance.id}' references unregistered sourceId '${instance.sourceId}'`,
+      );
+    }
+    if (registeredSource.archived === true) {
+      throw new IngestionConfigError(
+        `ingestion instance '${instance.id}' references archived sourceId '${instance.sourceId}'`,
+      );
+    }
+
+    const runtimeConfig: Record<string, unknown> = {
+      ...(loaded.declaration.default_config ?? {}),
+      ...(instance.config ?? {}),
+      id: instance.id,
+      sourceId: instance.sourceId,
+    };
+
+    let source: unknown;
+    try {
+      source = loaded.factory(runtimeConfig);
+    } catch {
+      // Do not echo factory errors: adapters may include config values or
+      // credentials in exception messages. Instance/kind are non-secret IDs.
+      throw new IngestionConfigError(
+        `ingestion instance '${instance.id}' factory for kind '${instance.kind}' failed`,
+      );
+    }
+
+    assertIngestionSource(source, instance.id);
+    if (source.id !== instance.id) {
+      throw new IngestionConfigError(
+        `ingestion instance '${instance.id}' factory returned mismatched source identity`,
+      );
+    }
+    if (source.kind !== instance.kind) {
+      throw new IngestionConfigError(
+        `ingestion instance '${instance.id}' factory returned mismatched source kind`,
+      );
+    }
+
+    registrations.push({ source, sourceId: instance.sourceId, config: runtimeConfig });
+  }
+
+  return registrations;
+}
+
+function assertIngestionSource(
+  value: unknown,
+  instanceId: string,
+): asserts value is SourceRegistration['source'] {
+  if (value === null || typeof value !== 'object' || Array.isArray(value)) {
+    throw invalidFactoryResult(instanceId);
+  }
+  const source = value as Record<string, unknown>;
+  if (typeof source.id !== 'string' || source.id.length === 0 ||
+      typeof source.kind !== 'string' || source.kind.length === 0 ||
+      typeof source.start !== 'function' || typeof source.stop !== 'function') {
+    throw invalidFactoryResult(instanceId);
+  }
+  if (source.mode !== undefined && source.mode !== 'trickle' && source.mode !== 'migration') {
+    throw invalidFactoryResult(instanceId);
+  }
+  if (source.healthCheck !== undefined && typeof source.healthCheck !== 'function') {
+    throw invalidFactoryResult(instanceId);
+  }
+}
+
+function invalidFactoryResult(instanceId: string): IngestionConfigError {
+  return new IngestionConfigError(
+    `ingestion instance '${instanceId}' factory returned an invalid source`,
+  );
+}
+
+function validateInstance(raw: unknown): IngestionInstanceConfig {
+  if (raw === null || typeof raw !== 'object' || Array.isArray(raw)) {
+    throw new IngestionConfigError('ingestion source instance must be an object');
+  }
+  const value = raw as Record<string, unknown>;
+  const id = typeof value.id === 'string' && value.id.length > 0
+    ? value.id
+    : '<unknown>';
+  if (id === '<unknown>') {
+    throw new IngestionConfigError('ingestion source instance requires id');
+  }
+  if (typeof value.kind !== 'string' || value.kind.length === 0) {
+    throw new IngestionConfigError(`ingestion instance '${id}' requires kind`);
+  }
+  if (value.enabled !== undefined && typeof value.enabled !== 'boolean') {
+    throw new IngestionConfigError(
+      `ingestion instance '${id}' enabled must be boolean`,
+    );
+  }
+  if (typeof value.sourceId !== 'string' || value.sourceId.length === 0) {
+    throw new IngestionConfigError(`ingestion instance '${id}' requires sourceId`);
+  }
+  if (value.config !== undefined &&
+      (value.config === null || typeof value.config !== 'object' || Array.isArray(value.config))) {
+    throw new IngestionConfigError(
+      `ingestion instance '${id}' config must be a plain object`,
+    );
+  }
+  return value as unknown as IngestionInstanceConfig;
+}
+
+export const __testing = { validateInstance };
