+++ b/test/serve-http-ingest-source-binding.test.ts
@@ -0,0 +1,152 @@
+import { describe, expect, test } from 'bun:test';
+import {
+  buildIngestQueueOptions,
+  resolveIngestSlug,
+  resolveIngestSourceBinding,
+  submitIngestCapture,
+} from '../src/commands/serve-http.ts';
+import { defaultSlugForEvent } from '../src/core/minions/handlers/ingest-capture.ts';
+import type { IngestionEvent } from '../src/core/ingestion/types.ts';
+
+describe('POST /ingest trusted source binding', () => {
+  test('requires an authenticated write source', () => {
+    expect(resolveIngestSourceBinding(undefined, undefined)).toEqual({
+      ok: false,
+      status: 403,
+      error: 'source_binding_required',
+      message: 'POST /ingest requires an OAuth client with a registered write source',
+    });
+    expect(resolveIngestSourceBinding('   ', undefined)).toMatchObject({
+      ok: false,
+      error: 'source_binding_required',
+    });
+  });
+
+  test('uses the authenticated source when the caller makes no assertion', () => {
+    expect(resolveIngestSourceBinding('source-a', undefined)).toEqual({
+      ok: true,
+      sourceId: 'source-a',
+    });
+  });
+
+  test('allows a matching header only as an assertion', () => {
+    expect(resolveIngestSourceBinding('source-a', ' source-a ')).toEqual({
+      ok: true,
+      sourceId: 'source-a',
+    });
+  });
+
+  test('rejects a caller attempting to select another source', () => {
+    expect(resolveIngestSourceBinding('source-a', 'source-b')).toEqual({
+      ok: false,
+      status: 403,
+      error: 'source_mismatch',
+      message: 'X-Gbrain-Source-Id does not match the authenticated write source',
+    });
+  });
+});
+
+describe('POST /ingest canonical queue submission', () => {
+  test('case-equivalent slugs resolve to one canonical idempotency identity', () => {
+    const upper = resolveIngestSlug('Wiki/Page');
+    const lower = resolveIngestSlug('wiki/page');
+    expect(upper).toEqual({ ok: true, slug: 'wiki/page' });
+    expect(lower).toEqual(upper);
+    if (!upper.ok || !lower.ok) throw new Error('unexpected slug rejection');
+    expect(buildIngestQueueOptions('client', 'source', upper.slug, 'a'.repeat(64))).toEqual(
+      buildIngestQueueOptions('client', 'source', lower.slug, 'a'.repeat(64)),
+    );
+  });
+
+  test('invalid slugs return a fixed public envelope', () => {
+    const result = resolveIngestSlug('../secret-path');
+    expect(result).toEqual({
+      ok: false,
+      status: 400,
+      error: 'invalid_slug',
+      message: 'X-Gbrain-Slug is not a valid canonical page slug',
+    });
+    expect(JSON.stringify(result)).not.toContain('secret-path');
+  });
+
+  test('rejects the 51st distinct waiting submission without substituting another job', async () => {
+    const calls: Array<{ opts: Record<string, unknown>; id: number }> = [];
+    const queue = {
+      async add(_name: string, _data: Record<string, unknown>, opts: Record<string, unknown>) {
+        if (calls.length >= Number(opts.maxWaiting)) {
+          throw new Error('identity-preserving queue backpressure');
+        }
+        const id = calls.length + 1;
+        calls.push({ opts, id });
+        return { id };
+      },
+    };
+    const ids: Array<number | string> = [];
+    for (let i = 0; i < 51; i++) {
+      const result = await submitIngestCapture(
+        queue,
+        { event: { marker: i } },
+        buildIngestQueueOptions(
+          'client',
+          'source',
+          `slug/${i}`,
+          i.toString(16).padStart(64, '0'),
+        ),
+      );
+      if (result.ok) ids.push(result.job.id);
+      else expect(i).toBe(50);
+    }
+    expect(new Set(ids).size).toBe(50);
+    expect(calls).toHaveLength(50);
+    expect(calls.every(({ opts }) =>
+      opts.maxWaiting === 50 && opts.maxWaitingMode === 'reject')).toBe(true);
+  });
+
+  test('slugless retries share a key but the same content on another UTC date does not', () => {
+    const base = {
+      source_id: 'source',
+      source_kind: 'webhook',
+      source_uri: 'test',
+      content_type: 'text/plain' as const,
+      content: 'same content',
+      content_hash: 'a'.repeat(64),
+      untrusted_payload: true,
+    };
+    const dayOne = { ...base, received_at: '2026-07-10T23:59:59.000Z' } satisfies IngestionEvent;
+    const retry = { ...dayOne } satisfies IngestionEvent;
+    const dayTwo = { ...base, received_at: '2026-07-11T00:00:01.000Z' } satisfies IngestionEvent;
+    const key = (event: IngestionEvent) => buildIngestQueueOptions(
+      'client',
+      event.source_id,
+      defaultSlugForEvent(event),
+      event.content_hash,
+    ).idempotency_key;
+    expect(defaultSlugForEvent(dayOne)).toBe('inbox/2026-07-10-aaaaaa');
+    expect(defaultSlugForEvent(dayTwo)).toBe('inbox/2026-07-11-aaaaaa');
+    expect(key(retry)).toBe(key(dayOne));
+    expect(key(dayTwo)).not.toBe(key(dayOne));
+  });
+
+  test('queue errors are logged internally but never returned to callers', async () => {
+    const internal: string[] = [];
+    const queue = {
+      async add() {
+        throw new Error('SQL password=[REDACTED] relation private_table failed');
+      },
+    };
+    const result = await submitIngestCapture(
+      queue,
+      {},
+      buildIngestQueueOptions('client', 'source', 'slug', 'a'.repeat(64)),
+      (message) => internal.push(message),
+    );
+    expect(result).toEqual({
+      ok: false,
+      status: 503,
+      error: 'queue_submission_failed',
+      message: 'Event could not be queued; retry later.',
+    });
+    expect(internal.join(' ')).toContain('private_table');
+    expect(JSON.stringify(result)).not.toContain('private_table');
+  });
+});
