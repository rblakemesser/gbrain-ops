+      const remaining = (): number => Math.max(0, deadlineMs - (Date.now() - startedAt));
+      const disconnectReserve = Math.max(1, Math.floor(deadlineMs / 3));
+
+      try {
+        const stopped = ingestionService
+          ? await waitWithin(ingestionService.stop(), Math.max(1, remaining() - disconnectReserve))
