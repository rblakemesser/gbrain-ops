+import { afterEach, describe, expect, test } from 'bun:test';
+import { mkdtempSync, rmSync, writeFileSync } from 'node:fs';
+import { createServer } from 'node:net';
+import { join } from 'node:path';
+import { tmpdir } from 'node:os';
+import { PGLiteEngine } from '../src/core/pglite-engine.ts';
+import { runServe } from '../src/commands/serve.ts';
+import { withEnv } from './helpers/with-env.ts';
+
+const roots: string[] = [];
+afterEach(() => {
+  for (const root of roots.splice(0)) rmSync(root, { recursive: true, force: true });
+});
+
+function tempRoot(): string {
+  const root = mkdtempSync(join(tmpdir(), 'gbrain-http-startup-'));
+  roots.push(root);
+  writeFileSync(join(root, 'config.json'), JSON.stringify({ engine: 'pglite' }));
+  return root;
+}
+
+async function connectedEngine(root: string): Promise<{ engine: PGLiteEngine; disconnects: () => number }> {
+  const engine = new PGLiteEngine();
+  await engine.connect({ database_path: join(root, 'brain.pglite') });
+  let count = 0;
+  const original = engine.disconnect.bind(engine);
+  engine.disconnect = async () => {
+    count += 1;
+    await original();
+  };
+  return { engine, disconnects: () => count };
+}
+
+async function occupiedPort(): Promise<{ port: number; close: () => Promise<void> }> {
+  const server = createServer();
+  await new Promise<void>((resolve, reject) => {
+    server.once('error', reject);
+    server.listen(0, '127.0.0.1', resolve);
+  });
+  const address = server.address();
+  if (!address || typeof address === 'string') throw new Error('test listener did not bind');
+  return {
+    port: address.port,
+    close: () => new Promise<void>((resolve, reject) => server.close((error) => error ? reject(error) : resolve())),
+  };
+}
+
+describe('real HTTP owner startup failures', () => {
+  test('invalid bootstrap configuration rejects through owner cleanup', async () => {
+    const root = tempRoot();
+    const { engine, disconnects } = await connectedEngine(root);
+    await withEnv({ GBRAIN_HOME: root, GBRAIN_ADMIN_BOOTSTRAP_TOKEN: 'too-short' }, async () => {
+      await expect(runServe(engine, ['--http', '--port', '0', '--bind', '127.0.0.1'])).rejects.toThrow(
+        'GBrain HTTP owner failed to start',
+      );
+    });
+    expect(disconnects()).toBe(1);
+  });
+
+  test('asynchronous bind failure stops ingestion and disconnects the owner', async () => {
+    const root = tempRoot();
+    const occupied = await occupiedPort();
+    const { engine, disconnects } = await connectedEngine(root);
+    let starts = 0;
+    let stops = 0;
+    try {
+      await withEnv({
+        GBRAIN_HOME: root,
+        GBRAIN_ADMIN_BOOTSTRAP_TOKEN: 'A'.repeat(40),
+      }, async () => {
+        await expect(runServe(engine, [
+          '--http', '--with-ingestion', '--port', String(occupied.port), '--bind', '127.0.0.1',
+          '--suppress-bootstrap-token',
+        ], {
+          loadConfig: () => ({ engine: 'pglite' }),
+          createIngestionService: () => ({
+            start: async () => { starts += 1; },
+            stop: async () => { stops += 1; },
+            healthCheck: async () => ({
+              state: 'running',
+              daemon: null,
+              pending_dispatches: 0,
+              embedding: { running: false, requested: false, retries: 0, remaining_chunks: 0 },
+              last_dispatch_error: null,
+              last_embedding_error: null,
+            }),
+          }),
+        })).rejects.toThrow('GBrain HTTP owner failed to start');
+      });
+    } finally {
+      await occupied.close();
+    }
