+    engine: BrainEngine,
+    config: GBrainConfig,
+    loaded: readonly LoadedIngestionSource[],
+  ) => Promise<SourceRegistration[]>;
+  persist: (engine: BrainEngine, event: IngestionEvent) => Promise<IngestCaptureResult>;
+  embed: (engine: BrainEngine, signal: AbortSignal) => Promise<void>;
+  signature: () => string;
+  sleep: (ms: number, signal: AbortSignal) => Promise<void>;
+}
+
+export interface IngestionServiceOpts {
+  engine: BrainEngine;
+  config: GBrainConfig;
+  logger: Logger;
+  shutdownGraceMs?: number;
+  _deps?: Partial<ServiceDependencies>;
+}
+
+const BUILTIN_COMMAND_ARCHIVE: LoadedIngestionSource = {
+  plugin_name: 'gbrain',
+  declaration: {
+    kind: 'command-archive',
+    module: 'builtin:command-archive',
+    api_version: 'gbrain-ingestion-source-v1',
+  },
+  factory: createCommandArchiveSource,
+  module_path: 'builtin:command-archive',
+  plugin_root: 'builtin:gbrain',
+};
+
+const INITIAL_EMBED_RETRY_MS = 1_000;
+const MAX_EMBED_RETRY_MS = 60_000;
+
+export class IngestionService {
+  private readonly deps: ServiceDependencies;
+  private daemon: IngestionDaemon | null = null;
+  private state: IngestionServiceState = 'stopped';
+  private startedOnce = false;
+  private stopRequested = false;
+  private readonly startupAbort = new AbortController();
+  private startPromise: Promise<void> | null = null;
+  private stopPromise: Promise<void> | null = null;
+  private dispatchTail: Promise<void> = Promise.resolve();
+  private pendingDispatches = 0;
+  private lastDispatchError: string | null = null;
+  private embeddingRequested = false;
+  private embeddingRunning = false;
+  private embeddingRetries = 0;
+  private remainingChunks: number | null = null;
+  private lastEmbeddingError: string | null = null;
+  private embeddingAbort = new AbortController();
+  private embeddingLoop: Promise<void> | null = null;
+
+  constructor(private readonly opts: IngestionServiceOpts) {
+    this.deps = {
+      loadSkillpacks: async () => loadSkillpackSources(),
+      loadConfigured: loadConfiguredSources,
+      persist: async (engine, event) => persistIngestionEvent(engine, {
+        event,
+        sourceId: event.source_id,
+        noEmbed: true,
+      }),
+      embed: async (engine, signal) => {
+        await runEmbedCore(engine, { stale: true, catchUp: true, signal });
+      },
+      signature: currentEmbeddingSignature,
+      sleep: abortableSleep,
+      ...(opts._deps ?? {}),
+    };
+  }
+
+  get lifecycleState(): IngestionServiceState {
+    return this.state;
+  }
+
+  start(): Promise<void> {
+    if (this.startedOnce || this.state !== 'stopped') {
+      return Promise.reject(new Error(`IngestionService.start: invalid state '${this.state}'`));
+    }
+    this.startedOnce = true;
+    this.state = 'starting';
+    const internal = this.startInternal();
+    const abortWait = rejectOnAbort(
+      this.startupAbort.signal,
+      'IngestionService.start: stopped during startup',
+    );
+    const operation = Promise.race([internal, abortWait.promise]);
+    this.startPromise = operation;
+    void operation.finally(() => {
+      abortWait.cancel();
+      if (this.startPromise === operation) this.startPromise = null;
+    }).catch(() => undefined);
+    return operation;
+  }
+
+  private async startInternal(): Promise<void> {
+    try {
+      const loaded = await this.deps.loadSkillpacks();
+      this.throwIfStopRequested();
+      if (loaded.warnings.length > 0) {
+        this.opts.logger.warn(
+          `[ingestion] source loader reported ${loaded.warnings.length} warning(s)`,
+        );
+      }
+      const byKind = new Map<string, LoadedIngestionSource>();
+      for (const source of [BUILTIN_COMMAND_ARCHIVE, ...loaded.sources]) {
+        if (byKind.has(source.declaration.kind)) {
+          this.opts.logger.error(
+            `[ingestion] source kind collision '${source.declaration.kind}'`,
+          );
+          throw new Error(
+            `IngestionService.start: source kind collision '${source.declaration.kind}'`,
+          );
+        }
+        byKind.set(source.declaration.kind, source);
+      }
+      const registrations = await this.deps.loadConfigured(
+        this.opts.engine,
+        this.opts.config,
+        [...byKind.values()],
+      );
+      this.throwIfStopRequested();
+      this.daemon = new IngestionDaemon({
+        engine: this.opts.engine,
+        logger: this.opts.logger,
+        dispatch: (event) => this.enqueueDispatch(event),
+      });
+      for (const registration of registrations) this.daemon.register(registration);
+      await this.daemon.start();
+      this.throwIfStopRequested();
+      this.state = 'running';
+      this.requestEmbedding();
+    } catch (error) {
+      if (this.stopRequested) {
+        throw new Error('IngestionService.start: stopped during startup');
+      }
+      await this.daemon?.stop(this.opts.shutdownGraceMs ?? 5_000);
+      this.daemon = null;
+      this.state = 'failed';
+      throw new Error('IngestionService.start: startup failed');
+    }
+  }
+
+  stop(): Promise<void> {
+    if (this.stopPromise) return this.stopPromise;
+    if (this.state === 'stopped' && !this.startPromise) return Promise.resolve();
+    this.stopRequested = true;
+    this.startupAbort.abort();
+    this.stopPromise = this.performStop();
+    return this.stopPromise;
+  }
+
+  private async performStop(): Promise<void> {
+    this.state = 'draining';
+    const daemonAtStop = this.daemon;
+    const daemonStop = daemonAtStop?.stop(this.opts.shutdownGraceMs ?? 5_000);
+    await this.startPromise?.catch(() => undefined);
+    if (this.daemon && this.daemon !== daemonAtStop) {
+      await this.daemon.stop(this.opts.shutdownGraceMs ?? 5_000);
+    }
+    await daemonStop;
+    await this.dispatchTail;
+    this.embeddingRequested = false;
+    this.embeddingAbort.abort();
+    await this.embeddingLoop;
+    this.daemon = null;
+    this.state = 'stopped';
+  }
+
+  private throwIfStopRequested(): void {
+    if (this.stopRequested) {
+      throw new Error('IngestionService.start: stopped during startup');
+    }
+  }
+
+  async healthCheck(): Promise<IngestionServiceHealth> {
+    return {
+      state: this.state,
+      daemon: this.daemon ? await this.daemon.healthCheck() : null,
+      pending_dispatches: this.pendingDispatches,
+      embedding: {
+        running: this.embeddingRunning,
+        requested: this.embeddingRequested,
+        retries: this.embeddingRetries,
+        remaining_chunks: this.remainingChunks,
+      },
+      last_dispatch_error: this.lastDispatchError,
+      last_embedding_error: this.lastEmbeddingError,
+    };
+  }
+
+  private enqueueDispatch(event: IngestionEvent): Promise<IngestionEmitOutcome> {
+    if (this.state !== 'starting' && this.state !== 'running') {
+      return Promise.resolve({
+        kind: 'retryable',
+        source_id: event.source_id,
+        code: 'dispatch_failed',
+        message: 'ingestion service is draining',
+      });
+    }
+
+    this.pendingDispatches++;
+    const execute = async (): Promise<IngestionEmitOutcome> => {
+      try {
+        const result = await this.deps.persist(this.opts.engine, event);
+        const outcome = mapPersistenceResult(result, event.source_id);
+        if (outcome.kind === 'accepted' || outcome.kind === 'duplicate') {
+          this.lastDispatchError = null;
+          this.requestEmbedding();
+        } else {
+          this.lastDispatchError = outcome.message;
+        }
+        return outcome;
+      } catch {
+        this.lastDispatchError = 'persistence dispatch failed';
+        return {
+          kind: 'retryable',
+          source_id: event.source_id,
+          code: 'dispatch_failed',
+          message: 'persistence dispatch failed',
+        };
+      } finally {
+        this.pendingDispatches--;
+      }
+    };
+
+    const result = this.dispatchTail.then(execute, execute);
+    this.dispatchTail = result.then(() => undefined, () => undefined);
+    return result;
+  }
+
+  private requestEmbedding(): void {
+    if (this.state === 'draining' || this.state === 'stopped' || this.state === 'failed') return;
+    this.embeddingRequested = true;
+    if (this.embeddingLoop) return;
+    this.embeddingLoop = this.runEmbeddingLoop().finally(() => {
+      this.embeddingLoop = null;
+      if (this.embeddingRequested && this.state === 'running') this.requestEmbedding();
+    });
+  }
+
+  private async runEmbeddingLoop(): Promise<void> {
+    while (this.embeddingRequested && this.state !== 'draining' && this.state !== 'stopped') {
+      this.embeddingRequested = false;
+      this.embeddingRunning = true;
+      try {
+        await this.deps.embed(this.opts.engine, this.embeddingAbort.signal);
+        this.remainingChunks = await this.opts.engine.countStaleChunks({
+          signature: this.deps.signature(),
+        });
+        if (this.remainingChunks > 0) {
+          this.embeddingRetries++;
+          this.lastEmbeddingError = 'embedding work remains';
+          await this.waitForEmbeddingRetry();
+          this.embeddingRequested = true;
+        } else {
+          this.embeddingRetries = 0;
+          this.lastEmbeddingError = null;
+        }
+      } catch {
+        if (this.embeddingAbort.signal.aborted) break;
+        this.embeddingRetries++;
+        this.lastEmbeddingError = 'embedding pass failed';
+        await this.waitForEmbeddingRetry();
+        this.embeddingRequested = true;
+      } finally {
+        this.embeddingRunning = false;
+      }
+    }
+  }
+
+  private async waitForEmbeddingRetry(): Promise<void> {
+    const delay = Math.min(
+      INITIAL_EMBED_RETRY_MS * 2 ** Math.max(0, this.embeddingRetries - 1),
+      MAX_EMBED_RETRY_MS,
+    );
+    await this.deps.sleep(delay, this.embeddingAbort.signal);
+  }
+}
+
+function mapPersistenceResult(
+  result: IngestCaptureResult,
+  fallbackSourceId: string,
+): IngestionEmitOutcome {
+  const sourceId = result.source_id || fallbackSourceId;
+  if (result.error || !result.content_hash) {
+    return {
+      kind: 'retryable',
+      source_id: sourceId,
+      slug: result.slug,
+      code: 'dispatch_failed',
+      message: 'persistence did not acknowledge content',
+    };
+  }
+  if (result.status === 'imported') {
+    return {
+      kind: 'accepted',
+      source_id: sourceId,
+      slug: result.slug,
+      content_hash: result.content_hash,
+    };
+  }
+  if (result.status === 'skipped') {
+    return {
+      kind: 'duplicate',
+      source_id: sourceId,
+      slug: result.slug,
+      content_hash: result.content_hash,
+    };
+  }
+  return {
+    kind: 'retryable',
+    source_id: sourceId,
+    slug: result.slug,
+    code: 'dispatch_failed',
+    message: 'persistence did not acknowledge content',
+  };
+}
+
+async function abortableSleep(ms: number, signal: AbortSignal): Promise<void> {
+  if (signal.aborted) return;
+  await new Promise<void>((resolve) => {
+    const finish = () => {
+      clearTimeout(timer);
+      signal.removeEventListener('abort', finish);
+      resolve();
+    };
+    const timer = setTimeout(finish, ms);
+    timer.unref?.();
+    signal.addEventListener('abort', finish, { once: true });
+  });
+}
+
+function rejectOnAbort(signal: AbortSignal, message: string): {
+  promise: Promise<never>;
+  cancel: () => void;
+} {
+  let reject!: (error: Error) => void;
+  const promise = new Promise<never>((_resolve, fail) => { reject = fail; });
+  const onAbort = () => reject(new Error(message));
+  if (signal.aborted) {
+    onAbort();
+    return { promise, cancel: () => undefined };
+  }
+  signal.addEventListener('abort', onAbort, { once: true });
+  return {
+    promise,
+    cancel: () => signal.removeEventListener('abort', onAbort),
+  };
+}
+
+export const __testing = { mapPersistenceResult, BUILTIN_COMMAND_ARCHIVE };
