+import { afterAll, beforeAll, describe, expect, test } from 'bun:test';
+import { PGLiteEngine } from '../src/core/pglite-engine.ts';
+import { LATEST_VERSION, runMigrations } from '../src/core/migrate.ts';
+
+let engine: PGLiteEngine;
+
+beforeAll(async () => {
+  engine = new PGLiteEngine();
+  await engine.connect({});
+  await engine.initSchema();
+});
+
+afterAll(async () => {
+  await engine.disconnect();
+});
+
+describe('migration v125 brain identity singleton', () => {
+  test('creates one immutable store identity when upgrading from v124', async () => {
+    expect(LATEST_VERSION).toBe(125);
+    await engine.executeRaw('DROP TABLE brain_identity');
+    await engine.setConfig('version', '124');
+
+    const applied = await runMigrations(engine);
+    expect(applied).toEqual({ applied: 1, current: 125 });
+    const firstId = await engine.getBrainId();
+    expect(firstId).toMatch(/^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/);
+
+    const rows = await engine.executeRaw<{ singleton: boolean; brain_id: string }>(
+      'SELECT singleton, brain_id::text AS brain_id FROM brain_identity',
+    );
+    expect(rows).toEqual([{ singleton: true, brain_id: firstId }]);
+
+    expect(await runMigrations(engine)).toEqual({ applied: 0, current: 125 });
+    expect(await engine.getBrainId()).toBe(firstId);
+  });
+});
