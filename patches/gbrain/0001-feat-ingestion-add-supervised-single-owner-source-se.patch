+      this.cycleAbort = null;
+      this.health = { status: 'fail', message: 'failed' };
+      if (error instanceof CommandArchiveError) throw error;
+      throw new CommandArchiveError('command archive cycle failed');
+    }
+  }
+
+  async stop(): Promise<void> {
+    this.cycleAbort?.abort();
+    const child = this.activeChild;
+    if (!child || child.exitCode !== null || child.signalCode !== null) return;
+    await terminateChild(child, 'collector command stopped');
+    this.activeChild = null;
+  }
+
+  async healthCheck(): Promise<IngestionSourceHealth> {
+    return { ...this.health };
+  }
+}
+
+export function parseCommandArchiveConfig(raw: Record<string, unknown>): CommandArchiveConfig {
+  assertExactKeys(raw, ['id', 'sourceId', 'commands', 'roots', 'state_dir', 'result_contract'], 'config');
+  const id = nonEmptyString(raw.id, 'id');
+  const sourceId = nonEmptyString(raw.sourceId, 'sourceId');
+  if (!Array.isArray(raw.commands) || raw.commands.length === 0) {
+    throw new CommandArchiveError('commands must contain at least one command');
+  }
+  if (!Array.isArray(raw.roots) || raw.roots.length === 0) {
+    throw new CommandArchiveError('roots must contain at least one root');
+  }
+
+  const commandIds = new Set<string>();
+  const commands = raw.commands.map((value, index): CommandArchiveCommandConfig => {
+    const commandRaw = plainObject(value, `command[${index}]`);
+    assertExactKeys(commandRaw, ['id', 'role', 'argv', 'cwd', 'timeout_seconds'], 'command');
+    const commandId = nonEmptyString(commandRaw.id, 'command.id');
+    if (!/^[a-z0-9][a-z0-9._-]*$/i.test(commandId) || commandId === '.' || commandId === '..') {
+      throw new CommandArchiveError('command.id must be path-safe');
+    }
+    if (commandIds.has(commandId)) throw new CommandArchiveError('command.id must be unique');
+    commandIds.add(commandId);
+    if (commandRaw.role !== 'source' && commandRaw.role !== 'support') {
+      throw new CommandArchiveError("command.role must be 'source' or 'support'");
+    }
+    if (!Array.isArray(commandRaw.argv) || commandRaw.argv.length === 0 ||
+        !commandRaw.argv.every((item) => typeof item === 'string') || commandRaw.argv[0].length === 0) {
+      throw new CommandArchiveError('command.argv must be a non-empty string array');
+    }
+    const timeout = commandRaw.timeout_seconds;
+    if (!Number.isFinite(timeout) || !Number.isInteger(timeout) ||
+        (timeout as number) <= 0 || (timeout as number) > MAX_TIMEOUT_SECONDS) {
+      throw new CommandArchiveError(`command.timeout_seconds must be an integer from 1 to ${MAX_TIMEOUT_SECONDS}`);
+    }
+    const cwd = commandRaw.cwd;
+    if (cwd !== undefined && (typeof cwd !== 'string' || !isAbsolute(cwd))) {
+      throw new CommandArchiveError('command.cwd must be absolute');
+    }
+    return {
+      id: commandId,
+      role: commandRaw.role,
+      argv: [...commandRaw.argv] as [string, ...string[]],
+      ...(cwd === undefined ? {} : { cwd }),
+      timeout_seconds: timeout as number,
+    };
+  });
+  if (commands.filter((command) => command.role === 'source').length !== 1) {
+    throw new CommandArchiveError("commands must contain exactly one 'source' role");
+  }
+
+  const rootIds = new Set<string>();
+  const roots = raw.roots.map((value, index): CommandArchiveRootConfig => {
+    const rootRaw = plainObject(value, `root[${index}]`);
+    assertExactKeys(rootRaw, ['id', 'path', 'slug_prefix'], 'root');
+    const rootId = rootRaw.id === undefined && (raw.roots as unknown[]).length === 1
+      ? 'root'
+      : nonEmptyString(rootRaw.id, 'root.id');
+    if (!/^[a-z0-9][a-z0-9._-]*$/i.test(rootId) || rootId === '.' || rootId === '..') {
+      throw new CommandArchiveError('root.id must be path-safe');
+    }
+    if (rootIds.has(rootId)) throw new CommandArchiveError('root.id must be unique');
+    rootIds.add(rootId);
+    const rootPath = nonEmptyString(rootRaw.path, 'root.path');
+    if (!isAbsolute(rootPath)) throw new CommandArchiveError('root.path must be absolute');
+    const slugPrefix = rootRaw.slug_prefix;
+    if (slugPrefix !== undefined) {
+      if (typeof slugPrefix !== 'string' || slugPrefix.length === 0) {
+        throw new CommandArchiveError('root.slug_prefix must be a non-empty string');
+      }
+      validateSlug(`${slugPrefix}/placeholder`);
+    }
+    return { id: rootId, path: rootPath, ...(slugPrefix === undefined ? {} : { slug_prefix: slugPrefix }) };
+  });
+
+  const stateDir = nonEmptyString(raw.state_dir, 'state_dir');
+  if (!isAbsolute(stateDir)) throw new CommandArchiveError('state_dir must be absolute');
+
+  let resultContract: CommandArchiveResultContract | undefined;
+  if (raw.result_contract !== undefined) {
+    const contractRaw = plainObject(raw.result_contract, 'result_contract');
+    assertExactKeys(
+      contractRaw,
+      ['required', 'item_key_fields', 'account_fingerprint', 'requested_cutoff'],
+      'result_contract',
+    );
+    if (contractRaw.required !== true) {
+      throw new CommandArchiveError('result_contract.required must be true');
+    }
+    if (!Array.isArray(contractRaw.item_key_fields) || contractRaw.item_key_fields.length === 0 ||
+        !contractRaw.item_key_fields.every((field) => typeof field === 'string' && SAFE_TOKEN.test(field))) {
+      throw new CommandArchiveError('result_contract.item_key_fields must be non-empty safe field names');
+    }
+    if (new Set(contractRaw.item_key_fields).size !== contractRaw.item_key_fields.length) {
+      throw new CommandArchiveError('result_contract.item_key_fields must be unique');
+    }
+    if (!isSha256(contractRaw.account_fingerprint)) {
+      throw new CommandArchiveError('result_contract.account_fingerprint must be lowercase sha256');
+    }
+    const requestedCutoff = contractRaw.requested_cutoff;
+    if (requestedCutoff !== undefined && !isCanonicalIso(requestedCutoff)) {
+      throw new CommandArchiveError('result_contract.requested_cutoff must be canonical ISO');
+    }
+    resultContract = {
+      required: true,
+      item_key_fields: [...contractRaw.item_key_fields] as [string, ...string[]],
+      account_fingerprint: contractRaw.account_fingerprint,
+      ...(requestedCutoff === undefined ? {} : { requested_cutoff: requestedCutoff }),
+    };
+  }
+  return {
+    id,
+    sourceId,
+    commands: commands as [CommandArchiveCommandConfig, ...CommandArchiveCommandConfig[]],
+    roots: roots as [CommandArchiveRootConfig, ...CommandArchiveRootConfig[]],
+    state_dir: stateDir,
+    ...(resultContract === undefined ? {} : { result_contract: resultContract }),
+  };
+}
+
+interface StrictRootPlan {
+  root: string;
+  config: CommandArchiveRootConfig;
+  planned: PlannedArchive[];
+}
+
+async function runStrictCycle(
+  config: CommandArchiveConfig,
+  ctx: IngestionSourceContext,
+  signal: AbortSignal,
+  runIdFactory: () => string,
+  onChild: (child: ChildProcess) => void,
+  onChildDone: () => void,
+): Promise<void> {
+  const contract = config.result_contract!;
+  const runId = runIdFactory();
+  if (!SAFE_TOKEN.test(runId) || runId === '.' || runId === '..') {
+    throw new CommandArchiveError('collector run id is not path-safe');
+  }
+  const requestedCutoff = contract.requested_cutoff ?? new Date().toISOString();
+  const resolvedRoots = await Promise.all(config.roots.map(async (rootConfig) => ({
+    config: rootConfig,
+    root: await resolveArchiveRoot(rootConfig.path),
+  })));
+  const rootBindings = resolvedRoots.map(({ config: rootConfig, root }) => ({
+    id: rootConfig.id,
+    binding_sha256: sha256(root),
+  }));
+  const descriptors: CommandDescriptor[] = config.commands.map((command, index) => ({
+    index,
+    id: command.id,
+    role: command.role,
+    command_fingerprint: sha256(JSON.stringify({ argv: command.argv, cwd: command.cwd ?? null })),
+  }));
+  const inputMaterial = {
+    instance_id: config.id,
+    source_id: config.sourceId,
+    requested_cutoff: requestedCutoff,
+    account_fingerprint: contract.account_fingerprint,
+    item_key_fields: contract.item_key_fields,
+    commands: descriptors,
+    roots: rootBindings,
+  };
+  const inputSha256 = sha256(JSON.stringify(inputMaterial));
+  const runDir = join(config.state_dir, 'results', runId);
+  const inventoryDir = join(runDir, 'inventories');
+  const commands = descriptors.map((descriptor) => {
+    const stem = `${String(descriptor.index).padStart(4, '0')}-${descriptor.id}`;
+    return {
+      ...descriptor,
+      resultPath: join(runDir, `${stem}.json`),
+      inventoryPath: join(inventoryDir, `${stem}.jsonl`),
+    };
+  });
+  const run: StrictRun = { runId, runDir, requestedCutoff, inputSha256, commands };
+  const runInputPath = join(runDir, 'run-input.json');
+  const sourceResultPath = join(runDir, 'source-result.json');
+  const runInput = {
+    schema_version: RUN_INPUT_VERSION,
+    run_id: runId,
+    input_sha256: inputSha256,
+    ...inputMaterial,
+  };
+
+  await mkdir(inventoryDir, { recursive: true });
+  if (await pathExists(runInputPath)) {
+    const existing = await readCanonicalJson(runInputPath, 'run input');
+    if (JSON.stringify(existing) !== JSON.stringify(runInput)) {
+      throw new CommandArchiveError('RUN_INPUT_MISMATCH: existing run input does not match', 'RUN_INPUT_MISMATCH');
+    }
+    if (!(await pathExists(sourceResultPath))) {
+      throw new CommandArchiveError('RUN_OUTPUT_MISMATCH: existing run is incomplete', 'RUN_OUTPUT_MISMATCH');
+    }
+    const rootPlans = await scanStrictRoots(resolvedRoots, signal);
+    const validated = await validateStrictArtifacts(config, run, rootPlans, true);
+    const expected = buildSourceAggregate(
+      config,
+      run,
+      validated.members,
+      validated.inventories,
+      validated.memberHashes,
+      rootPlans,
+    );
+    const bytes = await readFile(sourceResultPath);
+    const canonical = Buffer.from(`${JSON.stringify(expected)}\n`);
+    if (!bytes.equals(canonical)) {
+      throw new CommandArchiveError('RUN_OUTPUT_MISMATCH: source aggregate does not match artifacts', 'RUN_OUTPUT_MISMATCH');
+    }
+    return;
+  }
+  if ((await readdir(runDir)).some((name) => name !== 'inventories')) {
+    throw new CommandArchiveError('RUN_OUTPUT_MISMATCH: run directory contains unbound output', 'RUN_OUTPUT_MISMATCH');
+  }
+  await writeAtomicJson(runInputPath, runInput, signal);
+
+  for (let index = 0; index < config.commands.length; index++) {
+    const command = config.commands[index]!;
+    const descriptor = commands[index]!;
+    await runCommand(command, signal, onChild, {
+      GBRAIN_COLLECTOR_RUN_ID: runId,
+      GBRAIN_COLLECTOR_SOURCE_ID: config.sourceId,
+      GBRAIN_COLLECTOR_CUTOFF: requestedCutoff,
+      GBRAIN_COLLECTOR_COMMAND_ID: command.id,
+      GBRAIN_COLLECTOR_RESULT_FILE: descriptor.resultPath,
+      GBRAIN_COLLECTOR_INVENTORY_FILE: descriptor.inventoryPath,
+    });
+    onChildDone();
+    await readAndValidateMember(config, run, descriptor);
+  }
+  let forgedSourceResult = false;
+  try {
+    await lstat(sourceResultPath);
+    forgedSourceResult = true;
+  } catch (error) {
+    if ((error as NodeJS.ErrnoException).code !== 'ENOENT') {
+      throw new CommandArchiveError('collector aggregate path could not be inspected');
+    }
+  }
+  if (forgedSourceResult) {
+    try { await unlink(sourceResultPath); } catch {
+      throw new CommandArchiveError('collector-created aggregate could not be removed');
+    }
+    throw new CommandArchiveError('collector run output set does not match adapter-owned artifacts');
+  }
+  await assertExactRunOutputs(run);
+  throwIfAborted(signal);
+  const rootPlans = await scanStrictRoots(resolvedRoots, signal);
+  const validated = await validateStrictArtifacts(config, run, rootPlans);
+
+  await ingestRootPlans(config, rootPlans, ctx, signal);
+  throwIfAborted(signal);
+  const aggregate = buildSourceAggregate(
+    config,
+    run,
+    validated.members,
+    validated.inventories,
+    validated.memberHashes,
+    rootPlans,
+  );
+  await writeAtomicJson(sourceResultPath, aggregate, signal);
+}
+
+async function scanStrictRoots(
+  roots: Array<{ config: CommandArchiveRootConfig; root: string }>,
+  signal: AbortSignal,
+): Promise<StrictRootPlan[]> {
+  const rootPlans: StrictRootPlan[] = [];
+  const slugs = new Set<string>();
+  const resolvedPaths = new Set<string>();
+  for (const { config, root } of roots) {
+    const planned = (await scanArchive(root, config.slug_prefix, signal))
+      .map((item) => ({ ...item, rootId: config.id }));
+    for (const item of planned) {
+      if (slugs.has(item.slug)) throw new CommandArchiveError('archive contains duplicate slug');
+      slugs.add(item.slug);
+      const resolved = await realpath(item.absolutePath);
+      if (resolvedPaths.has(resolved)) {
+        throw new CommandArchiveError('archive path resolves under multiple configured roots');
+      }
+      resolvedPaths.add(resolved);
+    }
+    rootPlans.push({ root, config, planned });
+  }
+  return rootPlans;
+}
+
+async function validateStrictArtifacts(
+  config: CommandArchiveConfig,
+  run: StrictRun,
+  rootPlans: StrictRootPlan[],
+  allowSourceResult = false,
+): Promise<{
+  members: CollectorMemberResultV1[];
+  inventories: ValidatedInventory[];
+  memberHashes: string[];
+}> {
+  await assertExactRunOutputs(run, allowSourceResult);
+  const members: CollectorMemberResultV1[] = [];
+  const inventories: ValidatedInventory[] = [];
+  const memberHashes: string[] = [];
+  for (const descriptor of run.commands) {
+    const member = await readAndValidateMember(config, run, descriptor);
+    const inventory = await validateInventory(config, member, descriptor, rootPlans);
+    if (member.archive_generation !== inventory.archiveGeneration) {
+      throw new CommandArchiveError('collector member archive generation does not match inventory mappings');
+    }
+    members.push(member);
+    inventories.push(inventory);
+    memberHashes.push(sha256(await readFile(descriptor.resultPath)));
+  }
+  const sourceIndexes = members
+    .map((member, index) => ({ member, index }))
+    .filter(({ member }) => member.inventory_artifact.inventory_kind === 'source');
+  if (sourceIndexes.length !== 1) {
+    throw new CommandArchiveError('collector run must contain exactly one source inventory');
+  }
+  const sourceInventory = inventories[sourceIndexes[0]!.index]!;
+  const sourcePaths = new Map<string, string>();
+  const sourceRows = new Map<string, InventoryRow>();
+  for (const row of sourceInventory.rows) {
+    const key = JSON.stringify(row.key);
+    sourceRows.set(key, row);
+    if (row.deleted) continue;
+    for (const archivePath of row.archive_paths) {
+      if (sourcePaths.has(archivePath)) {
+        throw new CommandArchiveError('source inventory maps an archive path more than once');
+      }
+      sourcePaths.set(archivePath, key);
+    }
+  }
+  const scannedPaths = rootPlans.flatMap((rootPlan) => rootPlan.planned.map(
+    (item) => `${rootPlan.config.id}/${item.relativePath}`,
+  )).sort(codeUnitCompare);
+  if (JSON.stringify([...sourcePaths.keys()].sort(codeUnitCompare)) !== JSON.stringify(scannedPaths)) {
+    throw new CommandArchiveError('source inventory archive mappings do not equal scanned archive');
+  }
+  for (let index = 0; index < inventories.length; index++) {
+    if (index === sourceIndexes[0]!.index) continue;
+    const derivedPaths = new Set<string>();
+    for (const row of inventories[index]!.rows) {
+      const key = JSON.stringify(row.key);
+      const sourceRow = sourceRows.get(key);
+      if (!sourceRow) throw new CommandArchiveError('derived inventory key is absent from source inventory');
+      if (row.deleted !== sourceRow.deleted) {
+        throw new CommandArchiveError('derived inventory deletion state does not match source inventory');
+      }
+      const allowedPaths = new Set(sourceRow.archive_paths);
+      for (const archivePath of row.archive_paths) {
+        if (!allowedPaths.has(archivePath)) {
+          throw new CommandArchiveError('derived inventory archive mapping does not match source key');
+        }
+        if (derivedPaths.has(archivePath)) {
+          throw new CommandArchiveError('derived inventory maps an archive path more than once');
+        }
+        derivedPaths.add(archivePath);
+      }
+    }
+  }
+  return { members, inventories, memberHashes };
+}
+
+async function readAndValidateMember(
+  config: CommandArchiveConfig,
+  run: StrictRun,
+  descriptor: StrictRun['commands'][number],
+): Promise<CollectorMemberResultV1> {
+  let parsed: unknown;
+  try {
+    parsed = JSON.parse(await readFile(descriptor.resultPath, 'utf8'));
+  } catch (error) {
+    if ((error as NodeJS.ErrnoException).code === 'ENOENT') {
+      throw new CommandArchiveError('collector command exited successfully without its result');
+    }
+    throw new CommandArchiveError('collector member result is malformed');
+  }
+  const member = plainObject(parsed, 'collector member result');
+  assertExactKeys(member, [
+    'schema_version', 'run_id', 'command_id', 'command_index', 'role', 'command_fingerprint',
+    'status', 'source_id', 'requested_cutoff', 'complete_through', 'account_fingerprint',
+    'cursor_sha256', 'watermark', 'counts', 'archive_generation', 'partial_failures',
+    'inventory_artifact',
+  ], 'collector member result');
+  const contract = config.result_contract!;
+  if (member.schema_version !== MEMBER_RESULT_VERSION || member.run_id !== run.runId ||
+      member.command_id !== descriptor.id || member.command_index !== descriptor.index ||
+      member.role !== descriptor.role || member.command_fingerprint !== descriptor.command_fingerprint ||
+      member.source_id !== config.sourceId || member.requested_cutoff !== run.requestedCutoff ||
+      member.account_fingerprint !== contract.account_fingerprint) {
+    throw new CommandArchiveError('collector member binding does not match run input');
+  }
+  if (member.status !== 'completed') {
+    throw new CommandArchiveError('collector member did not report completed status');
+  }
+  if (!isCanonicalIso(member.complete_through) ||
+      Date.parse(member.complete_through as string) < Date.parse(run.requestedCutoff)) {
+    throw new CommandArchiveError('collector member complete_through is before requested cutoff');
+  }
+  if (member.cursor_sha256 !== null && !isSha256(member.cursor_sha256)) {
+    throw new CommandArchiveError('collector member cursor hash is invalid');
+  }
+  if (member.watermark !== null) {
+    const watermark = plainObject(member.watermark, 'collector member watermark');
+    assertExactKeys(watermark, ['kind', 'value'], 'collector member watermark');
+    if (!['timestamp', 'rowid', 'source-specific'].includes(watermark.kind as string) ||
+        typeof watermark.value !== 'string' || watermark.value.length === 0) {
+      throw new CommandArchiveError('collector member watermark is invalid');
+    }
+  }
+  const counts = plainObject(member.counts, 'collector member counts');
+  assertExactKeys(counts, ['seen', 'changed', 'deleted'], 'collector member counts');
+  for (const value of [counts.seen, counts.changed, counts.deleted]) assertNonnegativeSafeInteger(value, 'collector member count');
+  if (!isSha256(member.archive_generation)) {
+    throw new CommandArchiveError('collector member archive generation is invalid');
+  }
+  if (!Array.isArray(member.partial_failures)) {
+    throw new CommandArchiveError('collector member partial_failures must be an array');
+  }
+  for (const value of member.partial_failures) {
+    const failure = plainObject(value, 'collector member partial failure');
+    assertExactKeys(failure, ['code', 'count'], 'collector member partial failure');
+    if (typeof failure.code !== 'string' || !SAFE_TOKEN.test(failure.code)) {
+      throw new CommandArchiveError('collector member partial failure code is invalid');
+    }
+    assertNonnegativeSafeInteger(failure.count, 'collector member partial failure count');
+  }
+  if (member.partial_failures.length !== 0) {
+    throw new CommandArchiveError('completed collector member cannot contain partial failures');
+  }
+  const artifact = plainObject(member.inventory_artifact, 'collector inventory artifact');
+  assertExactKeys(
+    artifact,
+    ['schema_version', 'inventory_kind', 'path', 'sha256', 'scope', 'item_key_fields', 'item_count'],
+    'collector inventory artifact',
+  );
+  const expectedKind = descriptor.role === 'source' ? 'source' : 'derived';
+  if (artifact.schema_version !== INVENTORY_VERSION || artifact.inventory_kind !== expectedKind ||
+      artifact.path !== descriptor.inventoryPath || !isSha256(artifact.sha256) ||
+      !['delta', 'full_through_cutoff'].includes(artifact.scope as string) ||
+      JSON.stringify(artifact.item_key_fields) !== JSON.stringify(contract.item_key_fields)) {
+    throw new CommandArchiveError('collector inventory artifact does not match run contract');
+  }
+  assertNonnegativeSafeInteger(artifact.item_count, 'collector inventory item_count');
+  if (contract.requested_cutoff !== undefined && artifact.scope !== 'full_through_cutoff') {
+    throw new CommandArchiveError('recovery collector inventory must be full_through_cutoff');
+  }
+  return member as unknown as CollectorMemberResultV1;
+}
+
+async function validateInventory(
+  config: CommandArchiveConfig,
+  member: CollectorMemberResultV1,
+  descriptor: StrictRun['commands'][number],
+  rootPlans: StrictRootPlan[],
+): Promise<ValidatedInventory> {
+  let bytes: Buffer;
+  try {
+    bytes = await readFile(descriptor.inventoryPath);
+  } catch {
+    throw new CommandArchiveError('collector inventory artifact is missing');
+  }
+  let text: string;
+  try {
+    text = new TextDecoder('utf-8', { fatal: true }).decode(bytes);
+  } catch {
+    throw new CommandArchiveError('collector inventory is not valid UTF-8');
+  }
+  if (!text.endsWith('\n')) throw new CommandArchiveError('collector inventory must be newline terminated');
+  const lines = text.slice(0, -1).length === 0 ? [] : text.slice(0, -1).split('\n');
+  if (lines.some((line) => line.length === 0)) throw new CommandArchiveError('collector inventory contains a blank line');
+  if (sha256(bytes) !== member.inventory_artifact.sha256) {
+    throw new CommandArchiveError('collector inventory sha256 does not match');
+  }
+  if (lines.length !== member.inventory_artifact.item_count) {
+    throw new CommandArchiveError('collector inventory item count does not match');
+  }
+
+  const pathMap = new Map<string, PlannedArchive>();
+  for (const rootPlan of rootPlans) {
+    for (const item of rootPlan.planned) pathMap.set(`${rootPlan.config.id}/${item.relativePath}`, item);
+  }
+  const rows: InventoryRow[] = [];
+  const mappedPaths = new Set<string>();
+  let previousKey: string | null = null;
+  for (const line of lines) {
+    let value: unknown;
+    try { value = JSON.parse(line); } catch { throw new CommandArchiveError('collector inventory row is malformed'); }
+    const raw = plainObject(value, 'collector inventory row');
+    assertExactKeys(raw, ['key', 'deleted', 'status', 'archive_paths', 'source_updated_at', 'content_hash'], 'collector inventory row');
+    if (!Array.isArray(raw.key) || raw.key.length !== config.result_contract!.item_key_fields.length ||
+        !raw.key.every((part) => (typeof part === 'string' && part.length > 0) ||
+          (typeof part === 'number' && Number.isSafeInteger(part)))) {
+      throw new CommandArchiveError('collector inventory key is invalid');
+    }
+    if (typeof raw.deleted !== 'boolean' ||
+        (raw.status !== null && typeof raw.status !== 'string') ||
+        !Array.isArray(raw.archive_paths) || !raw.archive_paths.every((path) => typeof path === 'string') ||
+        (raw.source_updated_at !== null && !isCanonicalIso(raw.source_updated_at)) ||
+        (raw.content_hash !== null && !isSha256(raw.content_hash))) {
+      throw new CommandArchiveError('collector inventory row fields are invalid');
+    }
+    const archivePaths = raw.archive_paths as string[];
+    if (JSON.stringify([...archivePaths].sort(codeUnitCompare)) !== JSON.stringify(archivePaths) ||
+        new Set(archivePaths).size !== archivePaths.length) {
+      throw new CommandArchiveError('collector inventory archive paths must be sorted and unique');
+    }
+    if ((raw.deleted && archivePaths.length !== 0) || (!raw.deleted && archivePaths.length === 0)) {
+      throw new CommandArchiveError('collector inventory live/deleted archive mapping is invalid');
+    }
+    for (const archivePath of archivePaths) {
+      if (mappedPaths.has(archivePath)) {
+        throw new CommandArchiveError('collector inventory maps an archive path more than once');
+      }
+      mappedPaths.add(archivePath);
+      const slash = archivePath.indexOf('/');
+      const rootId = slash < 0 ? '' : archivePath.slice(0, slash);
+      const relativePath = slash < 0 ? '' : archivePath.slice(slash + 1);
+      const rootPlan = rootPlans.find((candidate) => candidate.config.id === rootId);
+      if (!rootPlan || !isNormalizedRelativeMarkdownPath(relativePath)) {
+        throw new CommandArchiveError('collector inventory archive path is not a normalized root mapping');
+      }
+      const item = pathMap.get(archivePath);
+      if (!item) throw new CommandArchiveError('collector inventory archive path does not exist');
+      const resolved = await realpath(join(rootPlan.root, ...relativePath.split('/')));
+      const containingRoots = rootPlans.filter((candidate) => isContainedPath(candidate.root, resolved));
+      if (containingRoots.length !== 1 || resolved !== await realpath(item.absolutePath)) {
+        throw new CommandArchiveError('collector inventory archive path is not confined to exactly one root');
+      }
+    }
+    const row: InventoryRow = {
+      key: raw.key as Array<string | number>,
+      deleted: raw.deleted,
+      status: raw.status as string | null,
+      archive_paths: archivePaths,
+      source_updated_at: raw.source_updated_at as string | null,
+      content_hash: raw.content_hash as string | null,
+    };
+    if (line !== JSON.stringify(row)) throw new CommandArchiveError('collector inventory row is not canonical JSON');
+    const key = JSON.stringify(row.key);
+    if (previousKey !== null && codeUnitCompare(previousKey, key) >= 0) {
+      throw new CommandArchiveError('collector inventory keys must be strictly sorted and unique');
+    }
+    previousKey = key;
+    rows.push(row);
+  }
+  const deletedRows = rows.filter((row) => row.deleted).length;
+  const { seen, changed, deleted } = member.counts;
+  if (deleted !== deletedRows || changed > seen) {
+    throw new CommandArchiveError('collector member counts do not reconcile to inventory');
+  }
+  if (member.inventory_artifact.scope === 'full_through_cutoff') {
+    if (seen !== rows.length) {
+      throw new CommandArchiveError('collector member counts do not reconcile to full inventory');
+    }
+  } else if (changed + deleted !== rows.length || seen < rows.length) {
+    throw new CommandArchiveError('collector member counts do not reconcile to delta inventory');
+  }
+  return {
+    rows,
+    sha256: sha256(bytes),
+    archiveGeneration: archiveGeneration(
+      rows.flatMap((row) => row.archive_paths),
+      pathMap,
+    ),
+  };
+}
+
+function buildSourceAggregate(
+  config: CommandArchiveConfig,
+  run: StrictRun,
+  members: CollectorMemberResultV1[],
+  inventories: ValidatedInventory[],
+  memberHashes: string[],
+  rootPlans: StrictRootPlan[],
+): CommandArchiveSourceResultV1 {
+  const sourceIndex = members.findIndex((member) => member.inventory_artifact.inventory_kind === 'source');
+  const source = members[sourceIndex]!;
+  const completeThrough = members.map((member) => member.complete_through).sort(codeUnitCompare)[0]!;
+  const allPaths = rootPlans.flatMap((rootPlan) => rootPlan.planned.map(
+    (item) => `${rootPlan.config.id}/${item.relativePath}`,
+  ));
+  const pathMap = new Map(rootPlans.flatMap((rootPlan) => rootPlan.planned.map(
+    (item): [string, PlannedArchive] => [`${rootPlan.config.id}/${item.relativePath}`, item],
+  )));
+  return {
+    schema_version: SOURCE_RESULT_VERSION,
+    run_id: run.runId,
+    instance_id: config.id,
+    source_id: config.sourceId,
+    input_sha256: run.inputSha256,
+    requested_cutoff: run.requestedCutoff,
+    complete_through: completeThrough,
+    account_fingerprint: config.result_contract!.account_fingerprint,
+    commands: run.commands.map(({ resultPath: _resultPath, inventoryPath: _inventoryPath, ...descriptor }) => descriptor),
+    members: run.commands.map((descriptor, index) => ({
+      index: descriptor.index,
+      id: descriptor.id,
+      path: descriptor.resultPath,
+      sha256: memberHashes[index]!,
+      inventory_path: descriptor.inventoryPath,
+      inventory_sha256: inventories[index]!.sha256,
+    })),
+    source_inventory: {
+      path: source.inventory_artifact.path,
+      sha256: inventories[sourceIndex]!.sha256,
+      item_count: source.inventory_artifact.item_count,
+      scope: source.inventory_artifact.scope,
+    },
+    derived_inventories: members.flatMap((member, index) => member.inventory_artifact.inventory_kind === 'derived'
+      ? [{
+          command_id: member.command_id,
+          path: member.inventory_artifact.path,
+          sha256: inventories[index]!.sha256,
+          item_count: member.inventory_artifact.item_count,
+        }]
+      : []),
+    archive_generation: archiveGeneration(allPaths, pathMap),
+    verdict: 'completed',
+  };
+}
+
+async function assertExactRunOutputs(run: StrictRun, allowSourceResult = false): Promise<void> {
+  const expectedTopLevel = new Set([
+    'run-input.json',
+    'inventories',
+    ...run.commands.map((command) => command.resultPath.split('/').at(-1)!),
+  ]);
+  if (allowSourceResult) expectedTopLevel.add('source-result.json');
+  const topLevel = await readdir(run.runDir, { withFileTypes: true });
+  const actualTopLevel = topLevel.map((entry) => entry.name).sort(codeUnitCompare);
+  const expectedTopLevelNames = [...expectedTopLevel].sort(codeUnitCompare);
+  if (JSON.stringify(actualTopLevel) !== JSON.stringify(expectedTopLevelNames)) {
+    throw new CommandArchiveError('collector run output set does not match adapter-owned artifacts');
+  }
+  for (const entry of topLevel) {
+    const shouldBeDirectory = entry.name === 'inventories';
+    if ((shouldBeDirectory && !entry.isDirectory()) || (!shouldBeDirectory && !entry.isFile())) {
+      throw new CommandArchiveError('collector run output has an invalid artifact type');
+    }
+  }
+
+  const expectedInventories = run.commands
+    .map((command) => command.inventoryPath.split('/').at(-1)!)
+    .sort(codeUnitCompare);
+  const inventoryEntries = await readdir(join(run.runDir, 'inventories'), { withFileTypes: true });
+  const actualInventories = inventoryEntries.map((entry) => entry.name).sort(codeUnitCompare);
+  if (JSON.stringify(actualInventories) !== JSON.stringify(expectedInventories)) {
+    throw new CommandArchiveError('collector run inventory set does not match configured commands');
+  }
+  if (inventoryEntries.some((entry) => !entry.isFile())) {
+    throw new CommandArchiveError('collector run inventory has an invalid artifact type');
+  }
+}
+
+async function ingestRootPlans(
+  config: CommandArchiveConfig,
+  rootPlans: StrictRootPlan[],
+  ctx: IngestionSourceContext,
+  signal: AbortSignal,
+): Promise<void> {
+  const cycleStartedAt = new Date().toISOString();
+  for (const rootPlan of rootPlans) {
+    const manifestName = config.roots.length === 1 ? 'manifest.json' : `manifest-${rootPlan.config.id}.json`;
+    const manifestPath = join(config.state_dir, manifestName);
+    const manifest = await loadManifest(manifestPath, config, rootPlan.root, rootPlan.config.slug_prefix);
+    for (const item of rootPlan.planned) {
+      throwIfAborted(signal);
+      const prior = manifest.entries[item.relativePath];
+      if (prior && prior.archive_sha256 === item.archiveSha256 && prior.slug === item.slug &&
+          prior.source_uri === item.sourceUri) continue;
+      const event: IngestionEvent = {
+        source_id: config.sourceId,
+        source_kind: 'command-archive',
+        source_uri: item.sourceUri,
+        received_at: cycleStartedAt,
+        content_type: 'text/markdown',
+        content: item.content,
+        content_hash: computeContentHash(item.content),
+        untrusted_payload: false,
+        metadata: {
+          slug: item.slug,
+          archive_relative_path: item.relativePath,
+          archive_root_id: item.rootId,
+          archive_sha256: item.archiveSha256,
+        },
+      };
+      const outcome = await ctx.emitAsync(event);
+      assertAcknowledged(outcome, config.sourceId, item.slug);
+      throwIfAborted(signal);
+      manifest.entries[item.relativePath] = {
+        archive_sha256: item.archiveSha256,
+        slug: item.slug,
+        persisted_content_hash: outcome.content_hash,
+        source_uri: item.sourceUri,
+      };
+      await saveManifest(manifestPath, manifest, signal);
+    }
+  }
+}
+
+function archiveGeneration(paths: string[], pathMap: Map<string, PlannedArchive>): string {
+  const unique = [...new Set(paths)].sort(codeUnitCompare);
+  const entries = unique.map((path) => {
+    const item = pathMap.get(path);
+    if (!item) throw new CommandArchiveError('archive generation references an unknown path');
+    return { path, sha256: item.archiveSha256 };
+  });
+  return sha256(JSON.stringify(entries));
+}
+
+async function writeAtomicJson(path: string, value: unknown, signal?: AbortSignal): Promise<void> {
+  const directory = dirname(path);
+  await mkdir(directory, { recursive: true });
+  const tmp = `${path}.tmp`;
+  let handle;
+  try {
+    handle = await open(tmp, 'wx', 0o600);
+    await handle.writeFile(`${JSON.stringify(value)}\n`, 'utf8');
+    await handle.sync();
+    await handle.close();
+    handle = undefined;
+    throwIfAborted(signal);
+    await rename(tmp, path);
+    const directoryHandle = await open(directory, constants.O_RDONLY);
+    try { await directoryHandle.sync(); } finally { await directoryHandle.close(); }
+  } catch (error) {
+    try { await handle?.close(); } catch { /* best effort */ }
+    try { await unlink(tmp); } catch { /* best effort */ }
+    if (error instanceof CommandArchiveError) throw error;
+    throw new CommandArchiveError('collector artifact could not be committed');
+  }
+}
+
+async function readCanonicalJson(path: string, field: string): Promise<unknown> {
+  let text: string;
+  try { text = await readFile(path, 'utf8'); } catch { throw new CommandArchiveError(`${field} could not be read`); }
+  try {
+    const value = JSON.parse(text);
+    if (text !== `${JSON.stringify(value)}\n`) throw new Error('not canonical');
+    return value;
+  } catch {
+    throw new CommandArchiveError(`${field} is malformed`);
+  }
+}
+
+async function pathExists(path: string): Promise<boolean> {
+  try { await stat(path); return true; } catch (error) {
+    if ((error as NodeJS.ErrnoException).code === 'ENOENT') return false;
+    throw new CommandArchiveError('collector run path could not be inspected');
+  }
+}
+
+function sha256(value: string | Uint8Array): string {
+  return createHash('sha256').update(value).digest('hex');
+}
+
+function isCanonicalIso(value: unknown): value is string {
+  if (typeof value !== 'string') return false;
+  const milliseconds = Date.parse(value);
+  return Number.isFinite(milliseconds) && new Date(milliseconds).toISOString() === value;
+}
+
+function assertNonnegativeSafeInteger(value: unknown, field: string): asserts value is number {
+  if (typeof value !== 'number' || !Number.isSafeInteger(value) || value < 0) {
+    throw new CommandArchiveError(`${field} must be a nonnegative safe integer`);
+  }
+}
+
+function isContainedPath(root: string, candidate: string): boolean {
+  const rel = relative(root, candidate);
+  return rel !== '..' && !rel.startsWith(`..${sep}`) && !isAbsolute(rel);
+}
+
+async function runCommand(
+  config: CommandArchiveCommandConfig,
+  signal: AbortSignal,
+  onChild: (child: ChildProcess) => void,
+  envOverrides?: Record<string, string>,
+): Promise<void> {
+  throwIfAborted(signal);
+  await new Promise<void>((resolvePromise, rejectPromise) => {
+    let settled = false;
+    let stopReason: string | null = null;
+    let timeout: NodeJS.Timeout | null = null;
+    let killTimer: NodeJS.Timeout | null = null;
+    const child = spawn(config.argv[0], config.argv.slice(1), {
+      ...(config.cwd ? { cwd: config.cwd } : {}),
+      env: envOverrides ? { ...process.env, ...envOverrides } : process.env,
+      shell: false,
+      detached: process.platform !== 'win32',
+      stdio: ['ignore', 'ignore', 'ignore'],
+    });
+    onChild(child);
+
+    const finish = (error?: CommandArchiveError) => {
+      if (settled) return;
+      settled = true;
+      if (timeout) clearTimeout(timeout);
+      if (killTimer) clearTimeout(killTimer);
+      signal.removeEventListener('abort', onAbort);
+      if (error) rejectPromise(error);
+      else resolvePromise();
+    };
+    const requestStop = (reason: string) => {
+      if (settled || stopReason !== null) return;
+      stopReason = reason;
+      if (timeout) clearTimeout(timeout);
+      signalChild(child, 'SIGTERM');
+      killTimer = setTimeout(() => {
+        // The direct child exiting does not prove its descendants exited.
+        // Keep the original process-group escalation alive through grace.
+        signalChild(child, 'SIGKILL');
+        finish(new CommandArchiveError(reason));
+      }, KILL_GRACE_MS);
+      killTimer.unref?.();
+    };
+    const onAbort = () => requestStop('collector command aborted');
+    signal.addEventListener('abort', onAbort, { once: true });
+    timeout = setTimeout(
+      () => requestStop('collector command timed out'),
+      config.timeout_seconds * 1_000,
+    );
+    timeout.unref?.();
+    child.once('error', () => finish(new CommandArchiveError('collector command failed to spawn')));
+    child.once('exit', (code, exitSignal) => {
+      if (stopReason !== null) {
+        // Wait for the grace-period group SIGKILL before settling. A
+        // TERM-ignoring descendant may still be alive after this parent exits.
+        return;
+      } else if (exitSignal !== null) {
+        finish(new CommandArchiveError('collector command exited by signal'));
+      } else if (code !== 0) {
+        finish(new CommandArchiveError(`collector command exited with code ${code ?? 'unknown'}`));
+      } else {
+        finish();
+      }
+    });
+  });
+}
+
+function signalChild(child: ChildProcess, signal: NodeJS.Signals): void {
+  if (child.pid && process.platform !== 'win32') {
+    try {
+      process.kill(-child.pid, signal);
+      return;
+    } catch {
+      // The group may already be gone; fall back to the direct child handle.
+    }
+  }
+  try { child.kill(signal); } catch { /* already exited */ }
+}
+
+async function terminateChild(child: ChildProcess, _reason: string): Promise<void> {
+  if (child.exitCode !== null || child.signalCode !== null) return;
+  await new Promise<void>((resolvePromise) => {
+    signalChild(child, 'SIGTERM');
+    const killTimer = setTimeout(() => {
+      signalChild(child, 'SIGKILL');
+      resolvePromise();
+    }, KILL_GRACE_MS);
+    killTimer.unref?.();
+  });
+}
+
+async function resolveArchiveRoot(configuredRoot: string): Promise<string> {
+  let info;
+  try {
+    info = await lstat(configuredRoot);
+  } catch {
+    throw new CommandArchiveError('archive root does not exist');
+  }
+  if (info.isSymbolicLink() || !info.isDirectory()) {
+    throw new CommandArchiveError('archive root must be a real directory');
+  }
+  return realpath(configuredRoot);
+}
+
+async function scanArchive(
+  root: string,
+  prefix?: string,
+  signal?: AbortSignal,
+): Promise<Array<Omit<PlannedArchive, 'rootId'>>> {
+  const paths: Array<{ absolutePath: string; dev: number; ino: number }> = [];
+  async function walk(dir: string): Promise<void> {
+    throwIfAborted(signal);
+    const before = await lstat(dir);
+    if (before.isSymbolicLink() || !before.isDirectory()) {
+      throw new CommandArchiveError('archive directory changed during scan');
+    }
+    const resolvedDir = await realpath(dir);
+    assertContainedPath(root, resolvedDir);
+    const entries = await readdir(dir, { withFileTypes: true });
+    entries.sort((a, b) => codeUnitCompare(a.name, b.name));
+    for (const entry of entries) {
+      throwIfAborted(signal);
+      const absolutePath = join(dir, entry.name);
+      const current = await lstat(absolutePath);
+      if (current.isSymbolicLink()) throw new CommandArchiveError('archive contains a symbolic link');
+      if (current.isDirectory()) {
+        await walk(absolutePath);
+      } else if (current.isFile() && entry.name.toLowerCase().endsWith('.md')) {
+        paths.push({ absolutePath, dev: current.dev, ino: current.ino });
+      }
+    }
+    const after = await lstat(dir);
+    if (!after.isDirectory() || after.isSymbolicLink() || after.dev !== before.dev || after.ino !== before.ino) {
+      throw new CommandArchiveError('archive directory changed during scan');
+    }
+  }
+  await walk(root);
+  if (paths.length > MAX_FILES) throw new CommandArchiveError('archive exceeds file limit');
+
+  const planned: Array<Omit<PlannedArchive, 'rootId'>> = [];
+  const slugs = new Set<string>();
+  let totalBytes = 0;
+  for (const pathRecord of paths) {
+    throwIfAborted(signal);
+    const { absolutePath } = pathRecord;
+    const relativeNative = relative(root, absolutePath);
+    if (relativeNative === '' || relativeNative === '..' || relativeNative.startsWith(`..${sep}`)) {
+      throw new CommandArchiveError('archive path escaped root');
+    }
+    const relativePath = relativeNative.split(sep).join(posix.sep);
+    const before = await lstat(absolutePath);
+    if (!before.isFile() || before.isSymbolicLink() ||
+        before.dev !== pathRecord.dev || before.ino !== pathRecord.ino) {
+      throw new CommandArchiveError('archive file changed during scan');
+    }
+    const resolvedBefore = await realpath(absolutePath);
+    assertContainedPath(root, resolvedBefore);
+
+    let handle;
+    let bytes: Buffer;
+    try {
+      handle = await open(absolutePath, constants.O_RDONLY | constants.O_NOFOLLOW);
+      const opened = await handle.stat();
+      if (!opened.isFile() || opened.dev !== pathRecord.dev || opened.ino !== pathRecord.ino) {
+        throw new CommandArchiveError('archive file changed during scan');
+      }
+      bytes = await handle.readFile();
+    } catch (error) {
+      if (error instanceof CommandArchiveError) throw error;
+      throw new CommandArchiveError('archive file could not be read without following links');
+    } finally {
+      await handle?.close();
+    }
+
+    const after = await lstat(absolutePath);
+    const resolvedAfter = await realpath(absolutePath);
+    assertContainedPath(root, resolvedAfter);
+    if (!after.isFile() || after.isSymbolicLink() || after.dev !== pathRecord.dev ||
+        after.ino !== pathRecord.ino || resolvedAfter !== resolvedBefore) {
+      throw new CommandArchiveError('archive file changed during scan');
+    }
+    if (bytes.byteLength > MAX_FILE_BYTES) throw new CommandArchiveError('archive file exceeds size limit');
+    totalBytes += bytes.byteLength;
+    if (totalBytes > MAX_TOTAL_BYTES) throw new CommandArchiveError('archive exceeds total size limit');
+    let content: string;
+    try {
+      content = new TextDecoder('utf-8', { fatal: true }).decode(bytes);
+    } catch {
+      throw new CommandArchiveError('archive contains invalid UTF-8 Markdown');
+    }
+    const slug = validateSlug(pathToSlug(relativePath, prefix));
+    if (slug.length === 0) throw new CommandArchiveError('archive produced an empty slug');
+    if (slugs.has(slug)) throw new CommandArchiveError(`archive contains duplicate slug '${slug}'`);
+    slugs.add(slug);
+    planned.push({
+      absolutePath,
+      relativePath,
+      slug,
+      sourceUri: pathToFileURL(resolvedAfter).href,
+      content,
+      archiveSha256: createHash('sha256').update(bytes).digest('hex'),
+    });
+  }
+  planned.sort((a, b) => codeUnitCompare(a.relativePath, b.relativePath));
+  return planned;
+}
+
+async function loadManifest(
+  manifestPath: string,
+  config: CommandArchiveConfig,
+  root: string,
+  slugPrefix?: string,
+): Promise<CommandArchiveManifestV1> {
+  let text: string;
+  try {
+    text = await readFile(manifestPath, 'utf8');
+  } catch (error) {
+    if ((error as NodeJS.ErrnoException).code === 'ENOENT') {
+      return {
+        schema_version: MANIFEST_VERSION,
+        instance_id: config.id,
+        source_id: config.sourceId,
+        root,
+        entries: {},
+      };
+    }
+    throw new CommandArchiveError('manifest could not be read');
+  }
+  let parsed: unknown;
+  try { parsed = JSON.parse(text); } catch { throw new CommandArchiveError('manifest is malformed'); }
+  const manifest = plainObject(parsed, 'manifest');
+  assertExactKeys(manifest, ['schema_version', 'instance_id', 'source_id', 'root', 'entries'], 'manifest');
+  if (manifest.schema_version !== MANIFEST_VERSION || manifest.instance_id !== config.id ||
+      manifest.source_id !== config.sourceId || manifest.root !== root) {
+    throw new CommandArchiveError('manifest binding does not match configured source');
+  }
+  const entriesRaw = plainObject(manifest.entries, 'manifest.entries');
+  const entries: Record<string, ManifestEntry> = {};
+  for (const relativePath of Object.keys(entriesRaw).sort(codeUnitCompare)) {
+    if (!isNormalizedRelativeMarkdownPath(relativePath)) {
+      throw new CommandArchiveError('manifest entry path is invalid');
+    }
+    const entry = plainObject(entriesRaw[relativePath], 'manifest entry');
+    assertExactKeys(entry, ['archive_sha256', 'slug', 'persisted_content_hash', 'source_uri'], 'manifest entry');
+    const expectedPath = join(root, ...relativePath.split('/'));
+    assertContainedPath(root, expectedPath);
+    const expectedUri = pathToFileURL(expectedPath).href;
+    const expectedSlug = validateSlug(pathToSlug(relativePath, slugPrefix));
+    if (!isSha256(entry.archive_sha256) || !isSha256(entry.persisted_content_hash) ||
+        typeof entry.slug !== 'string' || entry.slug !== expectedSlug ||
+        entry.source_uri !== expectedUri) {
+      throw new CommandArchiveError('manifest entry is invalid');
+    }
+    entries[relativePath] = entry as unknown as ManifestEntry;
+  }
+  return {
+    schema_version: MANIFEST_VERSION,
+    instance_id: config.id,
+    source_id: config.sourceId,
+    root,
+    entries,
+  };
+}
+
+async function saveManifest(
+  path: string,
+  manifest: CommandArchiveManifestV1,
+  signal?: AbortSignal,
+): Promise<void> {
+  const directory = dirname(path);
+  await mkdir(directory, { recursive: true });
+  const sortedEntries: Record<string, ManifestEntry> = {};
+  for (const key of Object.keys(manifest.entries).sort(codeUnitCompare)) {
+    sortedEntries[key] = manifest.entries[key]!;
+  }
+  const payload = `${JSON.stringify({ ...manifest, entries: sortedEntries }, null, 2)}\n`;
+  const tmp = `${path}.tmp`;
+  let handle;
+  try {
+    handle = await open(tmp, 'w', 0o600);
+    await handle.writeFile(payload, 'utf8');
+    await handle.sync();
+    await handle.close();
+    handle = undefined;
+    throwIfAborted(signal);
+    await rename(tmp, path);
+    const directoryHandle = await open(directory, constants.O_RDONLY);
+    try {
+      await directoryHandle.sync();
+    } finally {
+      await directoryHandle.close();
+    }
+  } catch (error) {
+    try { await handle?.close(); } catch { /* best effort */ }
+    try { await unlink(tmp); } catch { /* absent or best-effort cleanup */ }
+    if (error instanceof CommandArchiveError) throw error;
+    throw new CommandArchiveError('manifest could not be committed');
+  }
+}
+
+function assertAcknowledged(outcome: IngestionEmitOutcome, sourceId: string, slug: string): asserts outcome is Extract<IngestionEmitOutcome, { kind: 'accepted' | 'duplicate' }> {
+  if ((outcome.kind !== 'accepted' && outcome.kind !== 'duplicate') ||
+      outcome.source_id !== sourceId || outcome.slug !== slug || !isSha256(outcome.content_hash)) {
+    throw new CommandArchiveError('sink did not acknowledge the planned archive identity');
+  }
+}
+
+function isSha256(value: unknown): value is string {
+  return typeof value === 'string' && /^[0-9a-f]{64}$/.test(value);
+}
+
+function plainObject(value: unknown, field: string): Record<string, unknown> {
+  if (value === null || typeof value !== 'object' || Array.isArray(value) ||
+      ![Object.prototype, null].includes(Object.getPrototypeOf(value))) {
+    throw new CommandArchiveError(`${field} must be a plain object`);
+  }
+  return value as Record<string, unknown>;
+}
+
+function throwIfAborted(signal?: AbortSignal): void {
+  if (signal?.aborted) throw new CommandArchiveError('collector command aborted');
+}
+
+function codeUnitCompare(a: string, b: string): number {
+  return a < b ? -1 : a > b ? 1 : 0;
+}
+
+function assertContainedPath(root: string, candidate: string): void {
+  const rel = relative(root, candidate);
+  if (rel === '..' || rel.startsWith(`..${sep}`) || isAbsolute(rel)) {
+    throw new CommandArchiveError('archive path escaped root');
+  }
+}
+
+function isNormalizedRelativeMarkdownPath(value: string): boolean {
