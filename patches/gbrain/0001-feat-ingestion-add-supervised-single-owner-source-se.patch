diff --git a/scripts/check-bun-version-sync.mjs b/scripts/check-bun-version-sync.mjs
new file mode 100644
index 00000000..00ea6b04
--- /dev/null
+++ b/scripts/check-bun-version-sync.mjs
@@ -0,0 +1,43 @@
+#!/usr/bin/env node
+
+import { readFileSync, readdirSync } from 'node:fs';
+import { join } from 'node:path';
+
+const pkg = JSON.parse(readFileSync(new URL('../package.json', import.meta.url), 'utf8'));
+const packageManager = String(pkg.packageManager ?? '');
+const required = packageManager.startsWith('bun@') ? packageManager.slice(4) : '';
+const engine = String(pkg.engines?.bun ?? '');
+
+if (!required) {
+  console.error('[check-bun-version-sync] FAIL: package.json packageManager must be bun@<exact-version>.');
+  process.exit(1);
+}
+if (engine !== required) {
+  console.error(`[check-bun-version-sync] FAIL: packageManager bun@${required} and engines.bun ${engine || '<missing>'} disagree.`);
+  process.exit(1);
+}
+
+const workflowsDir = new URL('../.github/workflows/', import.meta.url);
+const workflowFiles = readdirSync(workflowsDir)
+  .filter((name) => name.endsWith('.yml') || name.endsWith('.yaml'))
+  .sort();
+const mismatches = [];
+let pins = 0;
+for (const name of workflowFiles) {
+  const text = readFileSync(join(workflowsDir.pathname, name), 'utf8');
+  const regex = /^\s*bun-version:\s*["']?([^"'\s#]+)/gm;
+  for (const match of text.matchAll(regex)) {
+    pins++;
+    if (match[1] !== required) mismatches.push(`${name}:${match[1]}`);
+  }
+}
+if (pins === 0) {
+  console.error('[check-bun-version-sync] FAIL: no setup-bun workflow pins found.');
+  process.exit(1);
+}
+if (mismatches.length > 0) {
+  console.error(`[check-bun-version-sync] FAIL: CI Bun pins do not match bun@${required}: ${mismatches.join(', ')}`);
+  process.exit(1);
+}
+
+process.stdout.write(`${required}\n`);
diff --git a/scripts/check-pglite-open-gates.ts b/scripts/check-pglite-open-gates.ts
new file mode 100644
index 00000000..97800d68
--- /dev/null
+++ b/scripts/check-pglite-open-gates.ts
@@ -0,0 +1,176 @@
+#!/usr/bin/env bun
+import { existsSync, readdirSync, readFileSync, statSync } from 'node:fs';
+import { join, relative, resolve, sep } from 'node:path';
+import { fileURLToPath } from 'node:url';
+import ts from 'typescript';
+
+const CANONICAL = 'src/core/pglite-engine.ts';
+const CHECKER = 'scripts/check-pglite-open-gates.ts';
+const DIRECT_PATTERNS = [
+  /@electric-sql\/pglite/,
+  /\bPGlite\.create\s*\(/,
+  /\bnew\s+PGlite\s*\(/,
+  /pglite-lock\.ts/,
+];
+
+function walk(dir: string): string[] {
+  const files: string[] = [];
+  for (const entry of readdirSync(dir)) {
+    const path = join(dir, entry);
+    const stat = statSync(path);
+    if (stat.isDirectory()) files.push(...walk(path));
+    else if (/\.(?:ts|tsx|js|mjs|cjs)$/.test(entry)) files.push(path);
+  }
+  return files;
+}
+
+function executableIndex(text: string, pattern: RegExp): number {
+  return executableIndexes(text, pattern)[0] ?? -1;
+}
+
+function executableIndexes(text: string, pattern: RegExp): number[] {
+  const indexes: number[] = [];
+  let offset = 0;
+  for (const line of text.split('\n')) {
+    const trimmed = line.trimStart();
+    if (!trimmed.startsWith('//') && !trimmed.startsWith('*') && pattern.test(line)) indexes.push(offset);
+    offset += line.length + 1;
+  }
+  return indexes;
+}
+
+function executableLines(text: string): string[] {
+  return text.split('\n').filter((line) => {
+    const trimmed = line.trimStart();
+    return !trimmed.startsWith('//') && !trimmed.startsWith('*');
+  });
+}
+
+interface CanonicalAnalysis {
+  runtimePackageImports: number;
+  validPackageImports: number;
+  canonicalCreatePositions: number[];
+  hasAlternatePath: boolean;
+}
+
+function analyzeCanonical(text: string): CanonicalAnalysis {
+  const source = ts.createSourceFile(CANONICAL, text, ts.ScriptTarget.Latest, true, ts.ScriptKind.TS);
+  let runtimePackageImports = 0;
+  let validPackageImports = 0;
+  const canonicalCreatePositions: number[] = [];
+  let hasAlternatePath = false;
+
+  const isBasePackage = (node: ts.Expression | undefined): boolean =>
+    node !== undefined && ts.isStringLiteral(node) && node.text === '@electric-sql/pglite';
+
+  const visit = (node: ts.Node): void => {
+    if (ts.isImportDeclaration(node) && isBasePackage(node.moduleSpecifier)) {
+      const clause = node.importClause;
+      if (!clause?.isTypeOnly) {
+        runtimePackageImports += 1;
+        const bindings = clause?.namedBindings;
+        if (!clause?.name && bindings && ts.isNamedImports(bindings) && bindings.elements.length === 1) {
+          const element = bindings.elements[0]!;
+          if (!element.propertyName && element.name.text === 'PGlite') validPackageImports += 1;
+        }
+      }
+    }
+
+    if (ts.isExportDeclaration(node) && isBasePackage(node.moduleSpecifier)) {
+      if (!node.isTypeOnly) runtimePackageImports += 1;
+      hasAlternatePath = true;
+    }
+
+    if (ts.isCallExpression(node)) {
+      if (node.expression.kind === ts.SyntaxKind.ImportKeyword && isBasePackage(node.arguments[0])) {
+        runtimePackageImports += 1;
+        hasAlternatePath = true;
+      }
+      if (ts.isIdentifier(node.expression) && node.expression.text === 'require' && isBasePackage(node.arguments[0])) {
+        runtimePackageImports += 1;
+        hasAlternatePath = true;
+      }
+      if (ts.isPropertyAccessExpression(node.expression) && node.expression.name.text === 'create') {
+        const receiver = node.expression.expression;
+        if (ts.isIdentifier(receiver) && receiver.text === 'PGlite') {
+          canonicalCreatePositions.push(node.getStart(source));
+        } else if (!(ts.isIdentifier(receiver) && receiver.text === 'Object')) {
+          hasAlternatePath = true;
+        }
+      }
+      if (ts.isElementAccessExpression(node.expression)
+          && ts.isStringLiteral(node.expression.argumentExpression)
+          && node.expression.argumentExpression.text === 'create') {
+        hasAlternatePath = true;
+      }
+    }
+
+    if (ts.isIdentifier(node) && node.text === 'PGlite') {
+      const parent = node.parent;
+      const isImportBinding = ts.isImportSpecifier(parent) && parent.name === node;
+      const isTypeReference = ts.isTypeReferenceNode(parent);
+      const isCanonicalReceiver = ts.isPropertyAccessExpression(parent)
+        && parent.expression === node
+        && parent.name.text === 'create'
+        && ts.isCallExpression(parent.parent)
+        && parent.parent.expression === parent;
+      if (!isImportBinding && !isTypeReference && !isCanonicalReceiver) hasAlternatePath = true;
+    }
+
+    ts.forEachChild(node, visit);
+  };
+  visit(source);
+  return { runtimePackageImports, validPackageImports, canonicalCreatePositions, hasAlternatePath };
+}
+
+export function scanPgliteOpenGates(repoRoot: string): string[] {
+  const root = resolve(repoRoot);
+  const violations: string[] = [];
+  const productionFiles = ['src', 'scripts']
+    .map((directory) => join(root, directory))
+    .filter(existsSync)
+    .flatMap(walk);
+  for (const file of productionFiles) {
+    const rel = relative(root, file).split(sep).join('/');
+    const text = readFileSync(file, 'utf8');
+    if (rel === CANONICAL || rel === CHECKER) continue;
+    for (const pattern of DIRECT_PATTERNS) {
+      if (pattern.test(text)) {
+        violations.push(`${rel}: direct PGlite construction/import is forbidden; use PGLiteEngine.connect()`);
+        break;
+      }
+    }
+  }
+
+  const canonicalPath = join(root, CANONICAL);
+  const canonical = readFileSync(canonicalPath, 'utf8');
+  const lockImport = canonical.indexOf("from './pglite-lock.ts'");
+  const lockAcquire = executableIndex(canonical, /\bawait acquireLock\s*\(/);
+  const analysis = analyzeCanonical(canonical);
+  const creates = analysis.canonicalCreatePositions;
+  const create = creates[0] ?? -1;
+  if (lockImport < 0) violations.push(`${CANONICAL}: must import the canonical pglite-lock gate`);
+  if (lockAcquire < 0) violations.push(`${CANONICAL}: connect() must acquire pglite-lock`);
+  if (analysis.runtimePackageImports !== 1 || analysis.validPackageImports !== 1) {
+    violations.push(`${CANONICAL}: expected exactly one unaliased raw PGlite package import`);
+  }
+  if (creates.length !== 1) violations.push(`${CANONICAL}: expected exactly one canonical PGlite.create() call`);
+  if (analysis.hasAlternatePath) {
+    violations.push(`${CANONICAL}: alternate PGlite aliases/create paths are forbidden`);
+  }
+  if (lockAcquire >= 0 && create >= 0 && lockAcquire > create) {
+    violations.push(`${CANONICAL}: pglite-lock must be acquired before PGlite.create()`);
+  }
+  return violations;
+}
+
+if (import.meta.main) {
+  const repoRoot = resolve(fileURLToPath(new URL('..', import.meta.url)));
+  const violations = scanPgliteOpenGates(repoRoot);
+  if (violations.length > 0) {
+    console.error('check:pglite-open-gates failed:');
+    for (const violation of violations) console.error(`  - ${violation}`);
+    process.exit(1);
+  }
+  console.log('check:pglite-open-gates: ok (all production opens use PGLiteEngine.connect + pglite-lock)');
+}
