@@ -0,0 +1,281 @@
+import { describe, expect, test } from 'bun:test';
+import type { BrainEngine } from '../../src/core/engine.ts';
+import type { GBrainConfig } from '../../src/core/config.ts';
+import type { IngestionSource } from '../../src/core/ingestion/types.ts';
+import type { LoadedIngestionSource } from '../../src/core/ingestion/skillpack-load.ts';
+import { loadConfiguredSources } from '../../src/core/ingestion/config.ts';
+import { createCommandArchiveSource } from '../../src/core/ingestion/sources/command-archive.ts';
+
+function makeEngine(registeredIds: string[], archivedIds: string[] = []): BrainEngine {
+  return {
+    async executeRaw<T>(_sql: string, params?: unknown[]): Promise<T[]> {
+      const id = params?.[0];
+      if (typeof id !== 'string' || !registeredIds.includes(id)) return [];
+      return [{
+        id,
+        name: id,
+        local_path: null,
+        last_commit: null,
+        last_sync_at: null,
+        config: {},
+        created_at: new Date('2026-07-10T00:00:00Z'),
+        archived: archivedIds.includes(id),
+        newest_content_at: null,
+      } as T];
+    },
+  } as unknown as BrainEngine;
+}
+
+function makeLoadedSource(
+  factory: (config: Record<string, unknown>) => IngestionSource,
+  kind = 'archive',
+  defaultConfig: Record<string, unknown> = { interval: 60 },
+): LoadedIngestionSource {
+  return {
+    plugin_name: 'test-plugin',
+    declaration: {
+      kind,
+      module: './archive.js',
+      api_version: 'gbrain-ingestion-source-v1',
+      default_config: defaultConfig,
+    },
+    factory,
+    module_path: '/test/plugin/archive.js',
+    plugin_root: '/test/plugin',
+  };
+}
+
+function source(id: string, kind = 'archive'): IngestionSource {
+  return { id, kind, async start() {}, async stop() {} };
+}
+
+describe('loadConfiguredSources', () => {
+  test('binds the command-archive factory to its registered logical source', async () => {
+    const loaded = makeLoadedSource(createCommandArchiveSource, 'command-archive', {});
+    const configured: GBrainConfig = {
+      engine: 'pglite',
+      ingestion: {
+        sources: [{
+          id: 'mail-instance',
+          kind: 'command-archive',
+          sourceId: 'mail-archive',
+          config: {
+            commands: [{ id: 'collect', role: 'source', argv: ['/usr/bin/true'], timeout_seconds: 5 }],
+            roots: [{ path: '/private/mail', slug_prefix: 'mail' }],
+            state_dir: '/private/state/mail',
+          },
+        }],
+      },
+    };
+
+    const registrations = await loadConfiguredSources(
+      makeEngine(['mail-archive']),
+      configured,
+      [loaded],
+    );
+    expect(registrations).toHaveLength(1);
+    expect(registrations[0]?.source).toMatchObject({
+      id: 'mail-instance',
+      kind: 'command-archive',
+      mode: 'migration',
+    });
+    expect(registrations[0]?.sourceId).toBe('mail-archive');
+  });
+
+  test('rejects malformed top-level ingestion configuration', async () => {
+    for (const ingestion of [null, [], 'enabled']) {
+      const config = { engine: 'pglite', ingestion } as unknown as GBrainConfig;
+      await expect(loadConfiguredSources(makeEngine([]), config, []))
+        .rejects.toThrow('ingestion must be a plain object');
+    }
+
+    const config = {
+      engine: 'pglite',
+      ingestion: { enabled: 'false', sources: [] },
+    } as unknown as GBrainConfig;
+    await expect(loadConfiguredSources(makeEngine([]), config, []))
+      .rejects.toThrow('ingestion.enabled must be boolean');
+  });
+
+  test('projects an exact configured instance onto its registered source', async () => {
+    const captured: { config?: Record<string, unknown> } = {};
+    const loaded = makeLoadedSource((config) => {
+      captured.config = config;
+      return source('mail-instance');
+    });
+    const config: GBrainConfig = {
+      engine: 'pglite',
+      ingestion: {
+        enabled: true,
+        sources: [{
+          id: 'mail-instance',
+          kind: 'archive',
+          sourceId: 'mail-archive',
+          config: { interval: 120, stateDir: '/safe/state' },
+        }],
+      },
+    };
+
+    const registrations = await loadConfiguredSources(makeEngine(['mail-archive']), config, [loaded]);
+
+    expect(registrations).toHaveLength(1);
+    expect(registrations[0]?.source.id).toBe('mail-instance');
+    expect(registrations[0]?.sourceId).toBe('mail-archive');
+    expect(registrations[0]?.config).toEqual({
+      interval: 120,
+      stateDir: '/safe/state',
+      id: 'mail-instance',
+      sourceId: 'mail-archive',
+    });
+    expect(captured.config).toEqual(registrations[0]!.config);
+  });
+
+  test('rejects a configured instance missing sourceId before factory invocation', async () => {
+    let factoryCalled = false;
+    const loaded = makeLoadedSource(() => {
+      factoryCalled = true;
+      return source('mail-instance');
+    });
+    const config = {
+      engine: 'pglite',
+      ingestion: {
+        enabled: true,
+        sources: [{ id: 'mail-instance', kind: 'archive', config: {} }],
+      },
+    } as unknown as GBrainConfig;
+
+    await expect(loadConfiguredSources(makeEngine(['mail-archive']), config, [loaded]))
+      .rejects.toThrow("ingestion instance 'mail-instance' requires sourceId");
+    expect(factoryCalled).toBe(false);
+  });
+
+  test('rejects a disabled configured instance missing sourceId', async () => {
+    const config = {
+      engine: 'pglite',
+      ingestion: {
+        enabled: true,
+        sources: [{ id: 'mail-instance', kind: 'archive', enabled: false }],
+      },
+    } as unknown as GBrainConfig;
+
+    await expect(loadConfiguredSources(makeEngine([]), config, []))
+      .rejects.toThrow("ingestion instance 'mail-instance' requires sourceId");
+  });
+
+  test('rejects duplicate instance ids even when entries are disabled', async () => {
+    const throwingEngine = new Proxy({} as BrainEngine, {
+      get() { throw new Error('engine must not be touched'); },
+    });
+    for (const sources of [
+      [
+        { id: 'dup', kind: 'archive', sourceId: 'first', enabled: false },
+        { id: 'dup', kind: 'archive', sourceId: 'second' },
+      ],
+      [
+        { id: 'dup', kind: 'archive', sourceId: 'first', enabled: false },
+        { id: 'dup', kind: 'archive', sourceId: 'second', enabled: false },
+      ],
+    ]) {
+      const config: GBrainConfig = { engine: 'pglite', ingestion: { sources } };
+      await expect(loadConfiguredSources(throwingEngine, config, []))
+        .rejects.toThrow("duplicate ingestion instance id 'dup'");
+    }
+  });
+
+  test('rejects a factory whose source identity mismatches the configured instance', async () => {
+    const loaded = makeLoadedSource(() => source('different-instance'));
+    const config: GBrainConfig = {
+      engine: 'pglite',
+      ingestion: {
+        sources: [{ id: 'mail-instance', kind: 'archive', sourceId: 'mail-archive' }],
+      },
+    };
+
+    const error = loadConfiguredSources(makeEngine(['mail-archive']), config, [loaded]);
+    await expect(error).rejects.toThrow(
+      "ingestion instance 'mail-instance' factory returned mismatched source identity",
+    );
+    await expect(error).rejects.not.toThrow('different-instance');
+  });
+
+  test('rejects invalid factory return shapes deterministically', async () => {
+    const config: GBrainConfig = {
+      engine: 'pglite',
+      ingestion: {
+        sources: [{ id: 'mail-instance', kind: 'archive', sourceId: 'mail-archive' }],
+      },
+    };
+    const invalidValues: unknown[] = [
+      null,
+      {},
+      { id: 'mail-instance', kind: 'archive', stop: async () => {} },
+      { id: 'mail-instance', kind: 'archive', start: async () => {} },
+      { id: 'mail-instance', kind: 'archive', start: async () => {}, stop: async () => {}, healthCheck: true },
+    ];
+
+    for (const invalid of invalidValues) {
+      const loaded = makeLoadedSource(() => invalid as IngestionSource);
+      await expect(loadConfiguredSources(makeEngine(['mail-archive']), config, [loaded]))
+        .rejects.toThrow("ingestion instance 'mail-instance' factory returned an invalid source");
+    }
+  });
+
+  test('rejects an archived sourceId before factory invocation', async () => {
+    let factoryCalled = false;
+    const loaded = makeLoadedSource(() => {
+      factoryCalled = true;
+      return source('mail-instance');
+    });
+    const config: GBrainConfig = {
+      engine: 'pglite',
+      ingestion: {
+        sources: [{ id: 'mail-instance', kind: 'archive', sourceId: 'archived-source' }],
+      },
+    };
+
+    await expect(loadConfiguredSources(
+      makeEngine(['archived-source'], ['archived-source']),
+      config,
+      [loaded],
+    )).rejects.toThrow(
+      "ingestion instance 'mail-instance' references archived sourceId 'archived-source'",
+    );
+    expect(factoryCalled).toBe(false);
+  });
+
+  test('rejects an unregistered sourceId before factory invocation', async () => {
+    let factoryCalled = false;
+    const loaded = makeLoadedSource(() => {
+      factoryCalled = true;
+      return source('mail-instance');
+    });
+    const config: GBrainConfig = {
+      engine: 'pglite',
+      ingestion: {
+        sources: [{ id: 'mail-instance', kind: 'archive', sourceId: 'missing-source' }],
+      },
+    };
+
+    await expect(loadConfiguredSources(makeEngine([]), config, [loaded]))
+      .rejects.toThrow(
+        "ingestion instance 'mail-instance' references unregistered sourceId 'missing-source'",
+      );
+    expect(factoryCalled).toBe(false);
+  });
+
+  test('preserves compatibility when ingestion is absent or disabled', async () => {
+    const throwingEngine = new Proxy({} as BrainEngine, {
+      get() { throw new Error('engine must not be touched'); },
+    });
+    expect(await loadConfiguredSources(
+      throwingEngine,
+      { engine: 'pglite' },
+      [],
+    )).toEqual([]);
+    expect(await loadConfiguredSources(
+      throwingEngine,
+      { engine: 'pglite', ingestion: { enabled: false, sources: [] } },
+      [],
+    )).toEqual([]);
+  });
+});
