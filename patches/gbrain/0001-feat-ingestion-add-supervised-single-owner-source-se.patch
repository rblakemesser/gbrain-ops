+++ b/test/pglite-open-gates.test.ts
@@ -0,0 +1,148 @@
+import { afterEach, describe, expect, test } from 'bun:test';
+import { mkdtempSync, mkdirSync, rmSync, writeFileSync } from 'node:fs';
+import { join } from 'node:path';
+import { tmpdir } from 'node:os';
+import { scanPgliteOpenGates } from '../scripts/check-pglite-open-gates.ts';
+
+const roots: string[] = [];
+
+afterEach(() => {
+  for (const root of roots.splice(0)) rmSync(root, { recursive: true, force: true });
+});
+
+function fixture(canonical: string) {
+  const root = mkdtempSync(join(tmpdir(), 'gbrain-open-gate-'));
+  roots.push(root);
+  mkdirSync(join(root, 'src/core'), { recursive: true });
+  writeFileSync(join(root, 'src/core/pglite-engine.ts'), canonical);
+  return root;
+}
+
+const validCanonical = `
+import { PGlite } from '@electric-sql/pglite';
+import { acquireLock } from './pglite-lock.ts';
+export async function connect(dataDir: string) {
+  await acquireLock(dataDir);
+  return PGlite.create({ dataDir });
+}
+`;
+
+describe('check:pglite-open-gates', () => {
+  test('accepts the canonical lock-before-create owner path', () => {
+    expect(scanPgliteOpenGates(fixture(validCanonical))).toEqual([]);
+  });
+
+  test('rejects a direct PGlite import outside the canonical engine', () => {
+    const root = fixture(validCanonical);
+    writeFileSync(join(root, 'src/side-door.ts'), "import { PGlite } from '@electric-sql/pglite';\n");
+    expect(scanPgliteOpenGates(root)).toEqual([
+      'src/side-door.ts: direct PGlite construction/import is forbidden; use PGLiteEngine.connect()',
+    ]);
+  });
+
+  test('rejects a direct PGlite side door under scripts', () => {
+    const root = fixture(validCanonical);
+    mkdirSync(join(root, 'scripts'), { recursive: true });
+    writeFileSync(join(root, 'scripts/side-door.ts'), "import { PGlite } from '@electric-sql/pglite';\nawait PGlite.create('disk');\n");
+    expect(scanPgliteOpenGates(root)).toContain(
+      'scripts/side-door.ts: direct PGlite construction/import is forbidden; use PGLiteEngine.connect()',
+    );
+  });
+
+  test('rejects a second create inside the canonical engine', () => {
+    const root = fixture(validCanonical.replace(
+      'return PGlite.create({ dataDir });',
+      'await PGlite.create({ dataDir });\n  return PGlite.create({ dataDir });',
+    ));
+    expect(scanPgliteOpenGates(root)).toContain(
+      'src/core/pglite-engine.ts: expected exactly one canonical PGlite.create() call',
+    );
+  });
+
+  test('rejects a second package import aliased to another local identifier', () => {
+    const root = fixture(validCanonical.replace(
+      "import { PGlite } from '@electric-sql/pglite';",
+      "import { PGlite } from '@electric-sql/pglite';\nimport { PGlite as SideDoor } from '@electric-sql/pglite';",
+    ).replace(
+      'return PGlite.create({ dataDir });',
+      'await SideDoor.create({ dataDir });\n  return PGlite.create({ dataDir });',
+    ));
+    expect(scanPgliteOpenGates(root)).toContain(
+      'src/core/pglite-engine.ts: expected exactly one unaliased raw PGlite package import',
+    );
+    expect(scanPgliteOpenGates(root)).toContain(
+      'src/core/pglite-engine.ts: alternate PGlite aliases/create paths are forbidden',
+    );
+  });
+
+  test('rejects a local alias of the sole imported PGlite binding', () => {
+    const root = fixture(validCanonical.replace(
+      'return PGlite.create({ dataDir });',
+      'const SideDoor = PGlite;\n  await SideDoor.create({ dataDir });\n  return PGlite.create({ dataDir });',
+    ));
+    expect(scanPgliteOpenGates(root)).toContain(
+      'src/core/pglite-engine.ts: alternate PGlite aliases/create paths are forbidden',
+    );
+  });
+
+  test('rejects multiline dynamic package imports and aliased create calls', () => {
+    const root = fixture(validCanonical.replace(
+      'return PGlite.create({ dataDir });',
+      "const module = await import(\n    '@electric-sql/pglite'\n  );\n  await module.PGlite.create({ dataDir });\n  return PGlite.create({ dataDir });",
+    ));
+    expect(scanPgliteOpenGates(root)).toContain(
+      'src/core/pglite-engine.ts: expected exactly one unaliased raw PGlite package import',
+    );
+    expect(scanPgliteOpenGates(root)).toContain(
+      'src/core/pglite-engine.ts: alternate PGlite aliases/create paths are forbidden',
+    );
+  });
+
+  test('rejects bracketed create calls on the canonical binding', () => {
+    const root = fixture(validCanonical.replace(
+      'return PGlite.create({ dataDir });',
+      "await PGlite['create']({ dataDir });\n  return PGlite.create({ dataDir });",
+    ));
+    expect(scanPgliteOpenGates(root)).toContain(
+      'src/core/pglite-engine.ts: alternate PGlite aliases/create paths are forbidden',
+    );
+  });
+
+  test('rejects runtime re-exports of the PGlite package', () => {
+    const root = fixture(validCanonical.replace(
+      "import { PGlite } from '@electric-sql/pglite';",
+      "import { PGlite } from '@electric-sql/pglite';\nexport * from '@electric-sql/pglite';",
+    ));
+    expect(scanPgliteOpenGates(root)).toContain(
+      'src/core/pglite-engine.ts: expected exactly one unaliased raw PGlite package import',
+    );
+    expect(scanPgliteOpenGates(root)).toContain(
+      'src/core/pglite-engine.ts: alternate PGlite aliases/create paths are forbidden',
+    );
+  });
+
+  test('rejects extracting the canonical create method', () => {
+    const root = fixture(validCanonical.replace(
+      'return PGlite.create({ dataDir });',
+      'const open = PGlite.create;\n  await open({ dataDir });\n  return PGlite.create({ dataDir });',
+    ));
+    expect(scanPgliteOpenGates(root)).toContain(
+      'src/core/pglite-engine.ts: alternate PGlite aliases/create paths are forbidden',
+    );
+  });
+
+  test('rejects database creation before lock acquisition', () => {
+    const root = fixture(`
+import { PGlite } from '@electric-sql/pglite';
+import { acquireLock } from './pglite-lock.ts';
+export async function connect(dataDir: string) {
+  const db = await PGlite.create({ dataDir });
+  await acquireLock(dataDir);
+  return db;
+}
+`);
+    expect(scanPgliteOpenGates(root)).toContain(
+      'src/core/pglite-engine.ts: pglite-lock must be acquired before PGlite.create()',
+    );
+  });
+});
diff --git a/test/serve-http-ingest-source-binding.test.ts b/test/serve-http-ingest-source-binding.test.ts
