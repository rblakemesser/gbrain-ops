+        if (budgetMs <= 0) return false;
+        let timer: ReturnType<typeof setTimeout> | undefined;
+        const completed = await Promise.race([
+          work.then(() => true),
+          new Promise<false>((resolve) => {
+            timer = setTimeout(() => resolve(false), budgetMs);
+            timer.unref?.();
+          }),
+        ]);
+        if (timer) clearTimeout(timer);
