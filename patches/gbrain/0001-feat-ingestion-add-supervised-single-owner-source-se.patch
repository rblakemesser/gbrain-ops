diff --git a/test/ingestion/http-owner-vertical-slice.serial.test.ts b/test/ingestion/http-owner-vertical-slice.serial.test.ts
new file mode 100644
index 00000000..f7e59d30
--- /dev/null
+++ b/test/ingestion/http-owner-vertical-slice.serial.test.ts
@@ -0,0 +1,290 @@
+import { afterEach, describe, expect, test } from 'bun:test';
+import { EventEmitter } from 'node:events';
+import { mkdtemp, mkdir, rm, writeFile } from 'node:fs/promises';
+import { join } from 'node:path';
+import { tmpdir } from 'node:os';
+import { Client } from '@modelcontextprotocol/sdk/client/index.js';
+import { StreamableHTTPClientTransport } from '@modelcontextprotocol/sdk/client/streamableHttp.js';
+import { PGLiteEngine } from '../../src/core/pglite-engine.ts';
+import type { BrainEngine } from '../../src/core/engine.ts';
+import { addSource } from '../../src/core/sources-ops.ts';
+import { hashToken, generateToken } from '../../src/core/utils.ts';
+import { IngestionService } from '../../src/core/ingestion/service.ts';
+import { runServe, type HttpServerHandle, type IngestionLifecycle } from '../../src/commands/serve.ts';
+import { runServeHttp, type ServeHttpOptions } from '../../src/commands/serve-http.ts';
+import type { GBrainConfig } from '../../src/core/config.ts';
+import type { Logger } from '../../src/core/operations.ts';
+import { withEnv } from '../helpers/with-env.ts';
+
+const cleanup: string[] = [];
+const logger: Logger = { info() {}, warn() {}, error() {} };
+
+async function commitArchive(cwd: string, message: string): Promise<void> {
+  for (const args of [['init'], ['add', '-A'], ['commit', '-m', message]]) {
+    const proc = Bun.spawn(['git', ...args], {
+      cwd,
+      stdout: 'ignore',
+      stderr: 'pipe',
+      env: {
+        ...process.env,
+        GIT_AUTHOR_NAME: 'gbrain-test',
+        GIT_AUTHOR_EMAIL: 'gbrain-test@users.noreply.github.com',
+        GIT_COMMITTER_NAME: 'gbrain-test',
+        GIT_COMMITTER_EMAIL: 'gbrain-test@users.noreply.github.com',
+      },
+    });
+    if (await proc.exited !== 0) {
+      throw new Error(`git ${args[0]} failed: ${await new Response(proc.stderr).text()}`);
+    }
+  }
+}
+
+interface Counts { pages: number; versions: number; chunks: number; embeddings: number }
+
+interface RunningOwner {
+  server: Awaited<ReturnType<typeof runServeHttp>>;
+  service: IngestionService;
+  stop: () => Promise<void>;
+}
+
+afterEach(async () => {
+  await Promise.all(cleanup.splice(0).map((path) => rm(path, { recursive: true, force: true })));
+});
+
+async function counters(engine: PGLiteEngine, sourceId: string): Promise<Counts> {
+  const rows = await engine.executeRaw<Counts>(`
+    SELECT
+      (SELECT count(*)::int FROM pages WHERE source_id = $1) AS pages,
+      (SELECT count(*)::int FROM page_versions v JOIN pages p ON p.id = v.page_id WHERE p.source_id = $1) AS versions,
+      (SELECT count(*)::int FROM content_chunks c JOIN pages p ON p.id = c.page_id WHERE p.source_id = $1) AS chunks,
+      (SELECT count(*)::int FROM content_chunks c JOIN pages p ON p.id = c.page_id
+        WHERE p.source_id = $1 AND c.embedding IS NOT NULL) AS embeddings
+  `, [sourceId]);
+  return rows[0]!;
+}
+
+function config(archive: string, state: string): GBrainConfig {
+  return {
+    engine: 'pglite',
+    ingestion: {
+      enabled: true,
+      sources: [{
+        id: 'vertical-collector',
+        kind: 'command-archive',
+        sourceId: 'vertical-slice',
+        config: {
+          commands: [{ id: 'collect', role: 'source', argv: ['/usr/bin/true'], timeout_seconds: 5 }],
+          roots: [{ path: archive, slug_prefix: 'vertical' }],
+          state_dir: state,
+        },
+      }],
+    },
+  } as GBrainConfig;
+}
+
+async function deterministicEmbed(engine: BrainEngine): Promise<void> {
+  const pages = await engine.listPages({ sourceId: 'vertical-slice', limit: 100 });
+  for (const page of pages) {
+    const chunks = await engine.getChunks(page.slug, { sourceId: 'vertical-slice' });
+    if (chunks.length === 0 || chunks.every((chunk) => chunk.embedding)) continue;
+    await engine.upsertChunks(page.slug, chunks.map((chunk) => ({
+      chunk_index: chunk.chunk_index,
+      chunk_text: chunk.chunk_text,
+      chunk_source: chunk.chunk_source,
+      token_count: chunk.token_count ?? Math.ceil(chunk.chunk_text.length / 4),
+      embedding: new Float32Array(1536).fill(0.001),
+    })), { sourceId: 'vertical-slice' });
+  }
+}
+
+async function waitForEmbedded(engine: PGLiteEngine): Promise<Counts> {
+  for (let attempt = 0; attempt < 100; attempt += 1) {
+    const value = await counters(engine, 'vertical-slice');
+    if (value.chunks > 0 && value.embeddings === value.chunks) return value;
+    await Bun.sleep(10);
+  }
+  throw new Error('embedding work did not drain');
+}
+
+async function brainId(engine: PGLiteEngine): Promise<string> {
+  const rows = await engine.executeRaw<{ brain_id: string }>('SELECT brain_id FROM brain_identity LIMIT 1');
+  if (!rows[0]?.brain_id) throw new Error('brain identity missing');
+  return rows[0].brain_id;
+}
+
+async function addReadOnlyToken(engine: PGLiteEngine): Promise<string> {
+  const token = generateToken('gbrain_at_');
+  const clientId = 'vertical-read-client';
+  await engine.executeRaw(
+    `INSERT INTO oauth_clients
+      (client_id, client_name, client_secret_hash, scope, grant_types, redirect_uris,
+       token_endpoint_auth_method, federated_read)
+     VALUES ($1, 'Vertical read client', NULL, 'read', ARRAY['client_credentials'],
+       ARRAY[]::text[], 'none', ARRAY['vertical-slice'])`,
+    [clientId],
+  );
+  await engine.executeRaw(
+    `INSERT INTO oauth_tokens (token_hash, token_type, client_id, scopes, expires_at)
+     VALUES ($1, 'access', $2, ARRAY['read'], $3)`,
+    [hashToken(token), clientId, Math.floor(Date.now() / 1000) + 3600],
+  );
+  return token;
+}
+
+async function startOwner(
+  engine: PGLiteEngine,
+  cfg: GBrainConfig,
+): Promise<RunningOwner> {
+  const signals = new EventEmitter();
+  let server: Awaited<ReturnType<typeof runServeHttp>> | undefined;
+  let service: IngestionService | undefined;
+  let resolveExit!: () => void;
+  const exited = new Promise<void>((resolve) => { resolveExit = resolve; });
+  let disconnects = 0;
+  const originalDisconnect = engine.disconnect.bind(engine);
+  engine.disconnect = async () => {
+    disconnects += 1;
+    await originalDisconnect();
+  };
+
+  await runServe(engine, [
+    '--http', '--with-ingestion', '--port', '0', '--bind', '127.0.0.1', '--suppress-bootstrap-token',
+  ], {
+    signals: signals as unknown as Pick<NodeJS.Process, 'on'>,
+    exit: () => resolveExit(),
+    loadConfig: () => cfg,
+    createIngestionService: () => {
+      service = new IngestionService({ engine, config: cfg, logger, _deps: { embed: deterministicEmbed } });
+      return service as IngestionLifecycle;
+    },
+    runServeHttp: async (ownerEngine, options: ServeHttpOptions): Promise<HttpServerHandle> => {
+      expect(ownerEngine).toBe(engine);
+      server = await runServeHttp(ownerEngine, options);
+      return server;
+    },
+    cleanupDeadlineMs: 2_000,
+  });
+  if (!server || !service) throw new Error('owner failed to retain server/service');
+  return {
+    server,
+    service,
+    stop: async () => {
+      signals.emit('SIGTERM');
+      await exited;
+      expect(disconnects).toBe(1);
+    },
+  };
+}
+
+async function connectClient(server: RunningOwner['server'], token: string): Promise<Client> {
+  const address = server.address();
+  if (!address || typeof address === 'string') throw new Error('HTTP test listener missing TCP address');
+  const transport = new StreamableHTTPClientTransport(
+    new URL(`http://127.0.0.1:${address.port}/mcp`),
+    { requestInit: { headers: { Authorization: `Bearer ${token}` } } },
+  );
+  const client = new Client({ name: 'vertical-slice-test', version: '1.0.0' });
+  await client.connect(transport);
+  return client;
+}
+
+describe('collector → product owner → embedding → authenticated HTTP MCP', () => {
+  test('persists across owner restart, preserves identity, and replays with zero deltas', async () => {
+    const base = await mkdtemp(join(tmpdir(), 'gbrain-vertical-slice-'));
+    cleanup.push(base);
+    const archive = join(base, 'archive');
+    const state = join(base, 'state');
+    const database = join(base, 'brain.pglite');
+    await mkdir(archive, { recursive: true });
+    await writeFile(join(base, 'config.json'), JSON.stringify({ engine: 'pglite' }));
+    await writeFile(join(archive, 'proof.md'), '# Vertical Proof\n\nneedle-ulysses-7419\n');
+    await commitArchive(archive, 'initial archive fixture');
+    const cfg = config(archive, state);
+
+    await withEnv({
+      GBRAIN_HOME: base,
+      GBRAIN_ADMIN_BOOTSTRAP_TOKEN: 'A'.repeat(40),
+    }, async () => {
+      const engineOne = new PGLiteEngine();
+      await engineOne.connect({ database_path: database });
+      await engineOne.initSchema();
+      await addSource(engineOne, {
+        id: 'vertical-slice',
+        name: 'Vertical Slice',
+        localPath: archive,
+        federated: true,
+      });
+      await engineOne.setConfig('search.mcp_keyword_only', 'true');
+      const token = await addReadOnlyToken(engineOne);
+      const identityOne = await brainId(engineOne);
+
+      const ownerOne = await startOwner(engineOne, cfg);
+      const first = await waitForEmbedded(engineOne);
+      expect(first.pages).toBe(1);
+      expect(first.versions).toBe(0);
+      expect(first.chunks).toBeGreaterThan(0);
+      expect(first.embeddings).toBe(first.chunks);
+
+      const clientOne = await connectClient(ownerOne.server, token);
+      try {
+        const identity = await clientOne.callTool({ name: 'get_brain_identity', arguments: {} });
+        expect(JSON.stringify(identity)).toContain(identityOne);
+        const result = await clientOne.callTool({ name: 'search', arguments: { query: 'needle-ulysses-7419' } });
+        expect(JSON.stringify(result)).toContain('needle-ulysses-7419');
+        const denied = await clientOne.callTool({
+          name: 'put_page',
+          arguments: { slug: 'must-not-write', type: 'note', title: 'denied', compiled_truth: 'denied' },
+        });
+        expect(denied.isError).toBe(true);
+      } finally {
+        await clientOne.close();
+      }
+      await ownerOne.stop();
+
+      await writeFile(
+        join(archive, 'proof.md'),
+        '# Vertical Proof\n\nneedle-ulysses-7419\n\nchanged-version-proof\n',
+      );
+      await commitArchive(archive, 'update archive fixture');
+      const engineTwo = new PGLiteEngine();
+      await engineTwo.connect({ database_path: database });
+      await engineTwo.initSchema();
+      expect(await brainId(engineTwo)).toBe(identityOne);
+
+      const ownerTwo = await startOwner(engineTwo, cfg);
+      const changed = await waitForEmbedded(engineTwo);
+      expect(changed.pages).toBe(1);
+      expect(changed.versions).toBeGreaterThan(0);
+      expect(changed.chunks).toBeGreaterThan(0);
+      expect(changed.embeddings).toBe(changed.chunks);
+      const clientTwo = await connectClient(ownerTwo.server, token);
+      try {
+        const identity = await clientTwo.callTool({ name: 'get_brain_identity', arguments: {} });
+        expect(JSON.stringify(identity)).toContain(identityOne);
+        const result = await clientTwo.callTool({ name: 'search', arguments: { query: 'changed-version-proof' } });
+        expect(JSON.stringify(result)).toContain('changed-version-proof');
+      } finally {
+        await clientTwo.close();
+      }
+      await ownerTwo.stop();
+
+      const engineThree = new PGLiteEngine();
+      await engineThree.connect({ database_path: database });
+      await engineThree.initSchema();
+      expect(await brainId(engineThree)).toBe(identityOne);
+      const ownerThree = await startOwner(engineThree, cfg);
+      const replay = await waitForEmbedded(engineThree);
+      expect(replay).toEqual(changed);
+      const clientThree = await connectClient(ownerThree.server, token);
+      try {
+        const identity = await clientThree.callTool({ name: 'get_brain_identity', arguments: {} });
+        expect(JSON.stringify(identity)).toContain(identityOne);
+        const result = await clientThree.callTool({ name: 'search', arguments: { query: 'changed-version-proof' } });
+        expect(JSON.stringify(result)).toContain('changed-version-proof');
+      } finally {
+        await clientThree.close();
+      }
+      await ownerThree.stop();
+    });
+  }, 45_000);
+});
