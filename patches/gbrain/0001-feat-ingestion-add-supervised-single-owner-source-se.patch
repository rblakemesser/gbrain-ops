+interface StrictCollectorOptions {
+  exitCode?: number;
+  missingResult?: boolean;
+  resultText?: string;
+  memberPatch?: Record<string, unknown>;
+  artifactPatch?: Record<string, unknown>;
+  inventoryRows?: Array<Record<string, unknown>>;
+  derivedInventoryRows?: Array<Record<string, unknown>>;
+  inventoryText?: string;
+  artifactSha256?: string;
+  extraMember?: boolean;
+  extraInventory?: boolean;
+  extraArtifactName?: string;
+  extraInventoryArtifactName?: string;
+  logPath?: string;
+}
+
+const roots: string[] = [];
+let strictScriptSequence = 0;
+
+afterEach(async () => {
+  await Promise.all(roots.splice(0).map((root) => rm(root, { recursive: true, force: true })));
+});
+
+async function fixture(): Promise<{ base: string; archive: string; state: string }> {
+  const base = await mkdtemp(join(tmpdir(), 'gbrain-command-archive-'));
+  roots.push(base);
+  const archive = join(base, 'archive');
+  const state = join(base, 'state');
+  await mkdir(archive, { recursive: true });
+  return { base, archive, state };
+}
+
+function config(
+  archive: string,
+  state: string,
+  argv: [string, ...string[]] = ['/usr/bin/true'],
+): Record<string, unknown> {
+  return {
+    id: 'fixture-instance',
+    sourceId: 'fixture-source',
+    commands: [{
+      id: 'collect',
+      role: 'source',
+      argv,
+      timeout_seconds: 5,
+    }],
+    roots: [{ path: archive, slug_prefix: 'fixture' }],
+    state_dir: state,
+  };
+}
+
+function sha256(value: string | Uint8Array): string {
+  return createHash('sha256').update(value).digest('hex');
+}
+
+function strictConfig(
+  archive: string,
+  state: string,
+  argv: [string, ...string[]],
+): Record<string, unknown> {
+  const raw = config(archive, state, argv);
+  raw.roots = [{ id: 'root', path: archive, slug_prefix: 'fixture' }];
+  raw.result_contract = {
+    required: true,
+    item_key_fields: ['item_id'],
+    account_fingerprint: ACCOUNT_FINGERPRINT,
+    requested_cutoff: STRICT_CUTOFF,
+  };
+  return raw;
+}
+
+async function strictCollector(
+  fx: { base: string; archive: string },
+  options: StrictCollectorOptions = {},
+): Promise<[string, ...string[]]> {
+  const script = join(fx.base, `strict-${++strictScriptSequence}.ts`);
+  await writeFile(script, `
+    import { appendFile, readFile, writeFile } from 'node:fs/promises';
+    import { createHash } from 'node:crypto';
+    import { dirname, join } from 'node:path';
+    const options = ${JSON.stringify(options)};
+    const archiveRoot = process.argv[2];
+    const resultPath = process.env.GBRAIN_COLLECTOR_RESULT_FILE!;
+    const inventoryPath = process.env.GBRAIN_COLLECTOR_INVENTORY_FILE!;
+    if (options.logPath) await appendFile(options.logPath, process.env.GBRAIN_COLLECTOR_RUN_ID + '\\n');
+    if (!options.missingResult) {
+      const runInput = JSON.parse(await readFile(join(dirname(resultPath), 'run-input.json'), 'utf8'));
+      const descriptor = runInput.commands.find((value: any) => value.id === process.env.GBRAIN_COLLECTOR_COMMAND_ID);
+      const rows = (descriptor.role === 'support' && options.derivedInventoryRows) ? options.derivedInventoryRows : (options.inventoryRows ?? [{
+        key: ['page-1'], deleted: false, status: null,
+        archive_paths: ['root/page.md'], source_updated_at: null, content_hash: null,
+      }]);
+      const inventoryText = options.inventoryText ?? rows.map((row: unknown) => JSON.stringify(row)).join('\\n') + '\\n';
+      await writeFile(inventoryPath, inventoryText);
+      const inventorySha = createHash('sha256').update(inventoryText).digest('hex');
+      const paths = [...new Set(rows.flatMap((row: any) => row.archive_paths ?? []))].sort();
+      const generationEntries = [];
+      for (const archivePath of paths) {
+        const prefix = 'root/';
+        let bytes = Buffer.alloc(0);
+        if (archivePath.startsWith(prefix)) {
+          try { bytes = await readFile(join(archiveRoot, archivePath.slice(prefix.length))); } catch {}
+        }
+        generationEntries.push({ path: archivePath, sha256: createHash('sha256').update(bytes).digest('hex') });
+      }
+      const member = {
+        schema_version: 'gbrain-collector-result/v1',
+        run_id: process.env.GBRAIN_COLLECTOR_RUN_ID,
+        command_id: process.env.GBRAIN_COLLECTOR_COMMAND_ID,
+        command_index: descriptor.index,
+        role: descriptor.role,
+        command_fingerprint: descriptor.command_fingerprint,
+        status: 'completed',
+        source_id: process.env.GBRAIN_COLLECTOR_SOURCE_ID,
+        requested_cutoff: process.env.GBRAIN_COLLECTOR_CUTOFF,
+        complete_through: ${JSON.stringify(STRICT_COMPLETE)},
+        account_fingerprint: ${JSON.stringify(ACCOUNT_FINGERPRINT)},
+        cursor_sha256: null,
+        watermark: null,
+        counts: { seen: rows.length, changed: rows.length, deleted: rows.filter((row: any) => row.deleted).length },
+        archive_generation: createHash('sha256').update(JSON.stringify(generationEntries)).digest('hex'),
+        partial_failures: [],
+        inventory_artifact: {
+          schema_version: 'gbrain-source-inventory/v1', inventory_kind: descriptor.role === 'source' ? 'source' : 'derived',
+          path: inventoryPath, sha256: options.artifactSha256 ?? inventorySha,
+          scope: 'full_through_cutoff', item_key_fields: ['item_id'], item_count: rows.length,
+          ...(options.artifactPatch ?? {}),
+        },
+        ...(options.memberPatch ?? {}),
+      };
+      await writeFile(resultPath, options.resultText ?? JSON.stringify(member));
+      if (options.extraMember) await writeFile(join(dirname(resultPath), '9999-extra.json'), '{}');
+      if (options.extraInventory) await writeFile(join(dirname(inventoryPath), '9999-extra.jsonl'), '');
+      if (options.extraArtifactName) await writeFile(join(dirname(resultPath), options.extraArtifactName), 'unexpected');
+      if (options.extraInventoryArtifactName) await writeFile(join(dirname(inventoryPath), options.extraInventoryArtifactName), 'unexpected');
+    }
+    if (options.exitCode) process.exit(options.exitCode);
+  `);
+  return [process.execPath, script, fx.archive];
+}
+
+function strictSource(raw: Record<string, unknown>, runId: string): CommandArchiveSource {
+  return new CommandArchiveSource(parseCommandArchiveConfig(raw), () => runId);
+}
+
+function context(
+  outcome?: (event: IngestionEvent, index: number) => IngestionEmitOutcome | Promise<IngestionEmitOutcome>,
+  signal: AbortSignal = new AbortController().signal,
+): IngestionSourceContext & { events: IngestionEvent[] } {
+  const events: IngestionEvent[] = [];
+  return {
+    events,
+    emit() { throw new Error('command archive must use emitAsync'); },
+    async emitAsync(event) {
+      const index = events.length;
+      events.push(event);
+      if (outcome) return outcome(event, index);
+      return {
+        kind: 'accepted',
+        source_id: event.source_id,
+        slug: event.metadata!.slug as string,
+        content_hash: 'a'.repeat(64),
+      };
+    },
+    engine: {} as never,
+    logger: { info() {}, warn() {}, error() {} },
+    abortSignal: signal,
+    config: {},
+  };
+}
+
+async function waitForPidGone(pid: number, timeoutMs = 2_000): Promise<boolean> {
+  const deadline = Date.now() + timeoutMs;
+  while (Date.now() < deadline) {
+    try {
+      process.kill(pid, 0);
+    } catch {
+      return true;
+    }
+    await Bun.sleep(25);
+  }
+  return false;
+}
+
+async function manifestBytes(state: string): Promise<string> {
+  return readFile(join(state, 'manifest.json'), 'utf8');
+}
+
+async function expectStrictFailure(
+  options: StrictCollectorOptions,
+  expectedMessage: string,
+  runId: string,
+): Promise<void> {
+  const fx = await fixture();
+  await writeFile(join(fx.archive, 'page.md'), '# page\n');
+  const argv = await strictCollector(fx, options);
+  const source = strictSource(strictConfig(fx.archive, fx.state, argv), runId);
+  const ctx = context();
+  await expect(source.start(ctx)).rejects.toThrow(expectedMessage);
+  expect(ctx.events).toEqual([]);
+  expect(await source.healthCheck()).toEqual({ status: 'fail', message: 'failed' });
+  await expect(lstat(join(fx.state, 'manifest.json'))).rejects.toThrow();
+  await expect(lstat(join(fx.state, 'results', runId, 'source-result.json'))).rejects.toThrow();
+}
