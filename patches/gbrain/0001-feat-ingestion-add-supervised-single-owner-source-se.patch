+import { afterAll, describe, expect, test } from 'bun:test';
+import { mkdtemp, rm } from 'node:fs/promises';
+import { join } from 'node:path';
+import { tmpdir } from 'node:os';
+import { PGLiteEngine } from '../src/core/pglite-engine.ts';
+
+const roots: string[] = [];
+
+afterAll(async () => {
+  await Promise.all(roots.map((root) => rm(root, { recursive: true, force: true })));
+});
+
+describe('persistent brain identity', () => {
+  test('survives a file-backed PGLite owner restart', async () => {
+    const root = await mkdtemp(join(tmpdir(), 'gbrain-identity-'));
+    roots.push(root);
+    const databasePath = join(root, 'brain.pglite');
+
+    const first = new PGLiteEngine();
+    await first.connect({ database_path: databasePath });
+    await first.initSchema();
+    const firstId = await first.getBrainId();
+    await first.disconnect();
+
+    const second = new PGLiteEngine();
+    await second.connect({ database_path: databasePath });
+    await second.initSchema();
+    const secondId = await second.getBrainId();
+    await second.disconnect();
+
+    expect(secondId).toBe(firstId);
+    expect(secondId).toMatch(/^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/);
+  });
+});
