+++ b/test/serve-http-owner-lifecycle.test.ts
@@ -0,0 +1,137 @@
+import { describe, expect, test } from 'bun:test';
+import { EventEmitter } from 'node:events';
+import {
+  runServe,
+  type HttpServerHandle,
+  type IngestionLifecycle,
+  type ServeOptions,
+} from '../src/commands/serve.ts';
+import type { ServeHttpOptions } from '../src/commands/serve-http.ts';
+import type { BrainEngine } from '../src/core/engine.ts';
+import type { GBrainConfig } from '../src/core/config.ts';
+
+function harness(overrides: {
+  server?: HttpServerHandle;
+  runHttpError?: boolean;
+  ingestionStartError?: boolean;
+  ingestionStopHang?: boolean;
+  cleanupDeadlineMs?: number;
+} = {}) {
+  const events: string[] = [];
+  const signals = new EventEmitter();
+  let closeCallback: (() => void) | null = null;
+  const server = overrides.server ?? {
+    close(callback: () => void) {
+      events.push('listener-close');
+      closeCallback = callback;
+    },
+    closeAllConnections() {
+      events.push('connections-close');
+      closeCallback?.();
+    },
+  };
+  const engine = {
+    async disconnect() { events.push('engine-disconnect'); },
+  } as unknown as BrainEngine;
+  const ingestion: IngestionLifecycle = {
+    async start() {
+      events.push('ingestion-start');
+      if (overrides.ingestionStartError) throw new Error('secret startup failure');
+    },
+    async stop() {
+      events.push('ingestion-stop');
+      if (overrides.ingestionStopHang) await new Promise<void>(() => undefined);
+    },
+    async healthCheck() { return {} as never; },
+  };
+  let capturedOptions: ServeHttpOptions | null = null;
+  let resolveExit!: (code: number | undefined) => void;
+  const exited = new Promise<number | undefined>((resolve) => { resolveExit = resolve; });
+  const opts: ServeOptions = {
+    signals: signals as unknown as Pick<NodeJS.Process, 'on'>,
+    exit: (code) => { events.push(`exit:${code}`); resolveExit(code); },
+    log: (message) => events.push(`log:${message}`),
+    cleanupDeadlineMs: overrides.cleanupDeadlineMs ?? 50,
+    loadConfig: () => ({ engine: 'pglite' } as GBrainConfig),
+    createIngestionService: () => ingestion,
+    runServeHttp: async (_engine, options) => {
+      events.push('http-start');
+      capturedOptions = options;
+      if (overrides.runHttpError) throw new Error('secret listen failure');
+      return server;
+    },
+  };
+  return { engine, ingestion, signals, events, opts, exited, getOptions: () => capturedOptions };
+}
+
+describe('HTTP owner lifecycle', () => {
+  test('--with-ingestion starts one service on the supplied owner before HTTP', async () => {
+    const h = harness();
+    await runServe(h.engine, ['--http', '--with-ingestion'], h.opts);
+    expect(h.events.slice(0, 2)).toEqual(['ingestion-start', 'http-start']);
+    expect(h.getOptions()?.ingestionService).toBe(h.ingestion);
+  });
+
+  test('signal shutdown is idempotent and orders listener, ingestion, engine, exit', async () => {
+    const h = harness();
+    await runServe(h.engine, ['--http', '--with-ingestion'], h.opts);
+    h.signals.emit('SIGTERM');
+    h.signals.emit('SIGINT');
+    expect(await h.exited).toBe(0);
+    const shutdown = h.events.filter((event) =>
+      ['listener-close', 'ingestion-stop', 'connections-close', 'engine-disconnect', 'exit:0'].includes(event));
+    expect(shutdown).toEqual([
+      'listener-close',
+      'ingestion-stop',
+      'connections-close',
+      'engine-disconnect',
+      'exit:0',
+    ]);
+  });
+
+  test('HTTP startup failure stops ingestion and releases the owner engine', async () => {
+    const h = harness({ runHttpError: true });
+    await expect(runServe(h.engine, ['--http', '--with-ingestion'], h.opts))
+      .rejects.toThrow('GBrain HTTP owner failed to start');
+    expect(h.events).toContain('ingestion-stop');
+    expect(h.events).toContain('engine-disconnect');
+    expect(JSON.stringify(h.events)).not.toContain('secret listen failure');
+  });
+
+  test('ingestion startup failure releases the owner engine without starting HTTP', async () => {
+    const h = harness({ ingestionStartError: true });
+    await expect(runServe(h.engine, ['--http', '--with-ingestion'], h.opts))
+      .rejects.toThrow('GBrain HTTP owner failed to start');
+    expect(h.events).not.toContain('http-start');
+    expect(h.events).toContain('ingestion-stop');
+    expect(h.events).toContain('engine-disconnect');
+    expect(JSON.stringify(h.events)).not.toContain('secret startup failure');
+  });
+
+  test('plain HTTP mode does not construct ingestion but still owns engine shutdown', async () => {
+    const h = harness();
+    await runServe(h.engine, ['--http'], h.opts);
+    expect(h.events).toEqual(['http-start']);
+    expect(h.getOptions()?.ingestionService).toBeUndefined();
+    h.signals.emit('SIGHUP');
+    await h.exited;
+    expect(h.events).toContain('engine-disconnect');
+    expect(h.events).not.toContain('ingestion-stop');
+  });
+
+  test('total cleanup deadline forces connection closure and one exit', async () => {
+    const events: string[] = [];
+    const server: HttpServerHandle = {
+      close() { events.push('listener-close'); },
+      closeAllConnections() { events.push('connections-close'); },
+    };
+    const h = harness({ server, cleanupDeadlineMs: 12, ingestionStopHang: true });
+    await runServe(h.engine, ['--http', '--with-ingestion'], h.opts);
+    h.signals.emit('SIGTERM');
+    expect(await h.exited).toBe(0);
+    expect(events).toEqual(['listener-close', 'connections-close']);
+    expect(h.events).toContain('engine-disconnect');
+    expect(h.events.find((event) => event.includes('cleanup deadline'))).toBeDefined();
+    expect(h.events.filter((event) => event === 'exit:0')).toHaveLength(1);
+  });
+});
