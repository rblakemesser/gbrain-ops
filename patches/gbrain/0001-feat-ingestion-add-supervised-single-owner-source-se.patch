@@ -0,0 +1,409 @@
+import { describe, expect, test } from 'bun:test';
+import type { GBrainConfig } from '../../src/core/config.ts';
+import type { BrainEngine } from '../../src/core/engine.ts';
+import type { Logger } from '../../src/core/operations.ts';
+import {
+  IngestionService,
+  __testing,
+} from '../../src/core/ingestion/service.ts';
+import type {
+  LoadedIngestionSource,
+  SkillpackSourceLoadResult,
+} from '../../src/core/ingestion/skillpack-load.ts';
+import type {
+  IngestionEmitOutcome,
+  IngestionEvent,
+  IngestionSource,
+  IngestionSourceContext,
+  SourceRegistration,
+} from '../../src/core/ingestion/types.ts';
+import type { IngestCaptureResult } from '../../src/core/minions/handlers/ingest-capture.ts';
+
+const logger = {
+  debug() {},
+  info() {},
+  warn() {},
+  error() {},
+} as unknown as Logger;
+
+function captureLogger(): { logger: Logger; messages: string[] } {
+  const messages: string[] = [];
+  return {
+    logger: {
+      debug(message: string) { messages.push(message); },
+      info(message: string) { messages.push(message); },
+      warn(message: string) { messages.push(message); },
+      error(message: string) { messages.push(message); },
+    } as unknown as Logger,
+    messages,
+  };
+}
+
+function event(slug: string): IngestionEvent {
+  return {
+    source_id: 'mail',
+    source_kind: 'test-source',
+    source_uri: `test://${slug}`,
+    received_at: '2026-07-10T00:00:00.000Z',
+    content_type: 'text/markdown',
+    content: slug,
+    content_hash: 'a'.repeat(64),
+    metadata: { slug },
+  };
+}
+
+function result(
+  slug: string,
+  status: IngestCaptureResult['status'] = 'imported',
+  hash: string | null = 'b'.repeat(64),
+): IngestCaptureResult {
+  return {
+    source_id: 'mail',
+    slug,
+    status,
+    chunks: 1,
+    ...(hash !== null ? { content_hash: hash } : {}),
+    untrusted_payload: false,
+    source_kind: 'test-source',
+    source_uri: `test://${slug}`,
+    ingested_via: 'ingest_capture',
+  };
+}
+
+function source(
+  events: IngestionEvent[],
+  outcomes: IngestionEmitOutcome[],
+): IngestionSource {
+  return {
+    id: 'collector',
+    kind: 'test-source',
+    async start(ctx: IngestionSourceContext) {
+      outcomes.push(...await Promise.all(events.map((item) => ctx.emitAsync(item))));
+    },
+    async stop() {},
+  };
+}
+
+function harness(opts: {
+  source?: IngestionSource;
+  logger?: Logger;
+  loadSkillpacks?: () => Promise<SkillpackSourceLoadResult>;
+  loadConfigured?: (
+    engine: BrainEngine,
+    config: GBrainConfig,
+    loaded: readonly LoadedIngestionSource[],
+  ) => Promise<SourceRegistration[]>;
+  persist?: (engine: BrainEngine, item: IngestionEvent) => Promise<IngestCaptureResult>;
+  embed?: (engine: BrainEngine, signal: AbortSignal) => Promise<void>;
+  stale?: () => number | Promise<number>;
+  sleep?: (ms: number, signal: AbortSignal) => Promise<void>;
+  shutdownGraceMs?: number;
+}) {
+  let connectCalls = 0;
+  let disconnectCalls = 0;
+  const engine = {
+    connect: async () => { connectCalls++; },
+    disconnect: async () => { disconnectCalls++; },
+    countStaleChunks: async () => opts.stale ? await opts.stale() : 0,
+  } as unknown as BrainEngine;
+  const service = new IngestionService({
+    engine,
+    config: {} as GBrainConfig,
+    logger: opts.logger ?? logger,
+    shutdownGraceMs: opts.shutdownGraceMs,
+    _deps: {
+      loadSkillpacks: opts.loadSkillpacks ?? (async () => ({ sources: [], warnings: [] })),
+      loadConfigured: opts.loadConfigured ?? (async () => opts.source
+        ? [{ source: opts.source, sourceId: 'mail' }]
+        : []),
+      persist: opts.persist ?? (async (_engine, item) => result(item.metadata!.slug as string)),
+      embed: opts.embed ?? (async () => {}),
+      signature: () => 'test-model:3',
+      sleep: opts.sleep ?? (async () => {}),
+    },
+  });
+  return {
+    engine,
+    service,
+    connectionCounts: () => ({ connectCalls, disconnectCalls }),
+  };
+}
+
+async function waitFor(
+  predicate: () => boolean | Promise<boolean>,
+  timeoutMs = 1_000,
+): Promise<void> {
+  const deadline = Date.now() + timeoutMs;
+  while (Date.now() < deadline) {
+    if (await predicate()) return;
+    await Bun.sleep(5);
+  }
+  throw new Error('condition not reached');
+}
+
+describe('IngestionService owner-local composition', () => {
+  test('uses the supplied engine and serializes concurrent persistence FIFO', async () => {
+    const outcomes: IngestionEmitOutcome[] = [];
+    let concurrent = 0;
+    let maxConcurrent = 0;
+    const order: string[] = [];
+    const fx = harness({
+      source: source([event('a'), event('b'), event('c')], outcomes),
+      persist: async (_engine, item) => {
+        concurrent++;
+        maxConcurrent = Math.max(maxConcurrent, concurrent);
+        const slug = item.metadata!.slug as string;
+        order.push(slug);
+        await Bun.sleep(2);
+        concurrent--;
+        return result(slug);
+      },
+    });
+
+    await fx.service.start();
+    expect(order).toEqual(['a', 'b', 'c']);
+    expect(maxConcurrent).toBe(1);
+    expect(outcomes.map((item) => item.kind)).toEqual(['accepted', 'accepted', 'accepted']);
+    expect(fx.connectionCounts()).toEqual({ connectCalls: 0, disconnectCalls: 0 });
+    await fx.service.stop();
+    expect(fx.connectionCounts()).toEqual({ connectCalls: 0, disconnectCalls: 0 });
+  });
+
+  test('a failed dispatch does not poison the FIFO tail', async () => {
+    const outcomes: IngestionEmitOutcome[] = [];
+    let calls = 0;
+    const fx = harness({
+      source: source([event('bad'), event('good')], outcomes),
+      persist: async (_engine, item) => {
+        calls++;
+        if (calls === 1) throw new Error('secret database failure');
+        return result(item.metadata!.slug as string);
+      },
+    });
+
+    await fx.service.start();
+    expect(outcomes.map((item) => item.kind)).toEqual(['retryable', 'accepted']);
+    expect((outcomes[0] as { message: string }).message)
+      .toBe('persistence did not complete; retry the event');
+    expect(JSON.stringify(outcomes)).not.toContain('secret database failure');
+    await fx.service.stop();
+  });
+
+  test('maps persistence terminal states only with authoritative hashes', () => {
+    expect(__testing.mapPersistenceResult(result('a'), 'fallback').kind).toBe('accepted');
+    expect(__testing.mapPersistenceResult(result('a', 'skipped'), 'fallback').kind).toBe('duplicate');
+    expect(__testing.mapPersistenceResult(result('a', 'error'), 'fallback').kind).toBe('retryable');
+    expect(__testing.mapPersistenceResult(result('a', 'imported', null), 'fallback').kind)
+      .toBe('retryable');
+  });
+
+  test('runs an initial stale sweep and retries a durable remainder without overlap', async () => {
+    let embedCalls = 0;
+    let embedConcurrent = 0;
+    let maxEmbedConcurrent = 0;
+    const stale = [1, 0];
+    const fx = harness({
+      embed: async () => {
+        embedCalls++;
+        embedConcurrent++;
+        maxEmbedConcurrent = Math.max(maxEmbedConcurrent, embedConcurrent);
+        await Bun.sleep(1);
+        embedConcurrent--;
+      },
+      stale: () => stale.shift() ?? 0,
+      sleep: async () => {},
+    });
+
+    await fx.service.start();
+    await waitFor(async () => (await fx.service.healthCheck()).embedding.remaining_chunks === 0);
+    expect(embedCalls).toBe(2);
+    expect(maxEmbedConcurrent).toBe(1);
+    expect((await fx.service.healthCheck()).last_embedding_error).toBeNull();
+    await fx.service.stop();
+  });
+
+  test('burst acknowledgments coalesce embedding and health reports pending state', async () => {
+    const outcomes: IngestionEmitOutcome[] = [];
+    let embedCalls = 0;
+    let releaseEmbed!: () => void;
+    const firstEmbed = new Promise<void>((resolve) => { releaseEmbed = resolve; });
+    const fx = harness({
+      source: source([event('a'), event('b'), event('c')], outcomes),
+      embed: async () => {
+        embedCalls++;
+        if (embedCalls === 1) await firstEmbed;
+      },
+    });
+
+    const start = fx.service.start();
+    await waitFor(() => embedCalls === 1);
+    releaseEmbed();
+    await start;
+    await waitFor(async () => !(await fx.service.healthCheck()).embedding.running);
+    expect(embedCalls).toBeLessThanOrEqual(2);
+    expect((await fx.service.healthCheck()).pending_dispatches).toBe(0);
+    await fx.service.stop();
+    await fx.service.stop();
+    expect(fx.service.lifecycleState).toBe('stopped');
+  });
+
+  test('concurrent stop callers join the same complete source drain', async () => {
+    let stopEntered = false;
+    let releaseStop!: () => void;
+    const stopGate = new Promise<void>((resolve) => { releaseStop = resolve; });
+    const blockingSource: IngestionSource = {
+      id: 'collector',
+      kind: 'test-source',
+      async start() {},
+      async stop() {
+        stopEntered = true;
+        await stopGate;
+      },
+    };
+    const fx = harness({ source: blockingSource });
+    await fx.service.start();
+
+    const first = fx.service.stop();
+    await waitFor(() => stopEntered);
+    const second = fx.service.stop();
+    expect(second).toBe(first);
+    let secondResolved = false;
+    void second.then(() => { secondResolved = true; });
+    await Bun.sleep(10);
+    expect(secondResolved).toBe(false);
+    expect(fx.service.lifecycleState).toBe('draining');
+    releaseStop();
+    await Promise.all([first, second]);
+    expect(fx.service.lifecycleState).toBe('stopped');
+    expect((await fx.service.healthCheck()).daemon).toBeNull();
+  });
+
+  test('stop during asynchronous startup cannot resurrect the service', async () => {
+    let loaderEntered = false;
+    let releaseLoader!: () => void;
+    const loaderGate = new Promise<void>((resolve) => { releaseLoader = resolve; });
+    let configuredCalls = 0;
+    const fx = harness({
+      loadSkillpacks: async () => {
+        loaderEntered = true;
+        await loaderGate;
+        return { sources: [], warnings: [] };
+      },
+      loadConfigured: async () => {
+        configuredCalls++;
+        return [];
+      },
+    });
+
+    const starting = fx.service.start();
+    await waitFor(() => loaderEntered);
+    const stopping = fx.service.stop();
+    releaseLoader();
+    await expect(starting).rejects.toThrow('stopped during startup');
+    await stopping;
+    expect(configuredCalls).toBe(0);
+    expect(fx.service.lifecycleState).toBe('stopped');
+    expect((await fx.service.healthCheck()).daemon).toBeNull();
+  });
+
+  test('stop remains bounded when a pre-daemon loader never settles', async () => {
+    let loaderEntered = false;
+    const fx = harness({
+      shutdownGraceMs: 5,
+      loadSkillpacks: async () => {
+        loaderEntered = true;
+        await new Promise<void>(() => undefined);
+        return { sources: [], warnings: [] };
+      },
+    });
+    const starting = fx.service.start();
+    await waitFor(() => loaderEntered);
